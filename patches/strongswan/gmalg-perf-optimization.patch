+void gmalg_sm2_ke_preload_my_key(void)
+{
+	SM2_KEY sm2_key;
+	char *key_path = NULL;
+	char *password = NULL;
+	char *full_path = NULL;
+	FILE *fp;
+	int ret;
+
+	DBG1(DBG_IKE, "SM2-KEM: preloading SM2 private key for performance");
+
+	/* Get key path from config */
+	key_path = get_gmalg_config("enc_key", NULL);
+	if (key_path)
+	{
+		full_path = build_path(SWANCTL_PRIVATEDIR, key_path);
+		free(key_path);
+	}
+	else
+	{
+		/* Default path */
+		full_path = strdup(SWANCTL_DIR "/" SWANCTL_PRIVATEDIR "/enc_key.pem");
+	}
+
+	if (!full_path)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to build key path");
+		return;
+	}
+
+	/* Get password from config */
+	password = get_gmalg_config("enc_key_secret", NULL);
+
+	/* Try to load the key */
+	fp = fopen(full_path, "r");
+	if (!fp)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: cannot open key file for preloading: %s", full_path);
+		free(full_path);
+		if (password)
+		{
+			memwipe(password, strlen(password));
+			free(password);
+		}
+		return;
+	}
+
+	/* Try encrypted PEM first */
+	if (password && password[0])
+	{
+		memset(&sm2_key, 0, sizeof(SM2_KEY));
+		ret = sm2_private_key_info_decrypt_from_pem(&sm2_key, password, fp);
+		if (ret == 1)
+		{
+			/* Cache the key globally */
+			memcpy(&g_my_sm2_key, &sm2_key, sizeof(SM2_KEY));
+			g_my_sm2_key_set = TRUE;
+			DBG1(DBG_IKE, "SM2-KEM: preloaded SM2 private key successfully (encrypted PEM)");
+			fclose(fp);
+			free(full_path);
+			memwipe(password, strlen(password));
+			free(password);
+			memwipe(&sm2_key, sizeof(SM2_KEY));
+			return;
+		}
+		rewind(fp);
+	}
+
+	/* Try unencrypted PEM */
+	memset(&sm2_key, 0, sizeof(SM2_KEY));
+	ret = sm2_private_key_info_from_pem(&sm2_key, fp);
+	if (ret == 1)
+	{
+		/* Cache the key globally */
+		memcpy(&g_my_sm2_key, &sm2_key, sizeof(SM2_KEY));
+		g_my_sm2_key_set = TRUE;
+		DBG1(DBG_IKE, "SM2-KEM: preloaded SM2 private key successfully (unencrypted PEM)");
+		fclose(fp);
+		free(full_path);
+		if (password)
+		{
+			memwipe(password, strlen(password));
+			free(password);
+		}
+		memwipe(&sm2_key, sizeof(SM2_KEY));
+		return;
+	}
+
+	DBG1(DBG_IKE, "SM2-KEM: failed to preload SM2 private key from %s", full_path);
+	fclose(fp);
+	free(full_path);
+	if (password)
+	{
+		memwipe(password, strlen(password));
+		free(password);
+	}
+}
 
