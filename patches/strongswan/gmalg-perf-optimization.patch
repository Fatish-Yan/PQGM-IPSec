 #include "gmalg_plugin.h"
 
+/* Default paths (used as fallback when not configured) */
+#define SWANCTL_DIR "/usr/local/etc/swanctl"
+#define SWANCTL_PRIVATEDIR "private"
+#define SWANCTL_X509DIR "x509"
+
+/**
+ * Get gmalg plugin config from strongswan.conf
+ * @param key config key name (e.g., "enc_key")
+ * @param default_value default value if not configured
+ * @return config value (caller must free), or NULL
+ */
+static char* get_gmalg_config(const char *key, const char *default_value)
+{
+	char buf[256];
+	const char *value;
+
+	snprintf(buf, sizeof(buf), "charon.plugins.gmalg.%s", key);
+	value = lib->settings->get_str(lib->settings, buf, NULL);
+
+	if (value && value[0])
+	{
+		DBG1(DBG_IKE, "SM2-KEM: loaded config %s = %s", key, value);
+		return strdup(value);
+	}
+
+	if (default_value)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: using default %s = %s", key, default_value);
+		return strdup(default_value);
+	}
+
+	return NULL;
+}
+
+/**
+ * Build full path (if not absolute, prepend swanctl directory)
+ * @param subdir subdirectory (e.g., "private" or "x509")
+ * @param filename file name
+ * @return full path (caller must free)
+ */
+static char* build_path(const char *subdir, const char *filename)
+{
+	char buf[PATH_MAX];
+
+	if (!filename)
+		return NULL;
+
+	/* Absolute path - return as is */
+	if (filename[0] == '/')
+		return strdup(filename);
+
+	/* Relative path - prepend swanctl directory */
+	snprintf(buf, sizeof(buf), "%s/%s/%s", SWANCTL_DIR, subdir, filename);
+	return strdup(buf);
+}
