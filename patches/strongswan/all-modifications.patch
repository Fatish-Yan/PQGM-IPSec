+	else
 	{
-		/* during rekeying, we derive keys once all exchanges are done */
-		return derive_keys(this);
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: IKE_INTERMEDIATE #%d - no KE payload in response, certificates only",
