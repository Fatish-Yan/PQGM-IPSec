diff --git a/src/libstrongswan/plugins/gmalg/gmalg_hmac_signer.c b/src/libstrongswan/plugins/gmalg/gmalg_hmac_signer.c
new file mode 100644
index 0000000000..d7408c6eec
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_hmac_signer.c
@@ -0,0 +1,263 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_hmac_signer.c - HMAC-SM3 Integrity Algorithm Implementation
+ *
+ * Implements HMAC-SM3 integrity algorithm using the standard HMAC construction
+ * (RFC 2104) with SM3 hash function from GmSSL library.
+ */
+
+#include "gmalg_hmac_signer.h"
+
+#include <library.h>
+#include <crypto/prfs/prf.h>
+#include "gmalg_hasher.h"
+
+#ifdef HAVE_GMSSL
+#include <gmssl/sm3.h>
+#endif
+
+#define SM3_BLOCK_SIZE		64
+#define SM3_DIGEST_SIZE		32
+
+typedef struct private_hmac_sm3_signer_t private_hmac_sm3_signer_t;
+
+/**
+ * Private data of HMAC-SM3 signer
+ */
+struct private_hmac_sm3_signer_t {
+
+	/**
+	 * Public signer interface
+	 */
+	union {
+		gmalg_hmac_sm3_128_signer_t hmac128;
+		gmalg_hmac_sm3_256_signer_t hmac256;
+	} public;
+
+	/**
+	 * Truncation length (16 for 128-bit, 32 for 256-bit)
+	 */
+	size_t truncation;
+
+	/**
+	 * SM3 hash context
+	 */
+#ifdef HAVE_GMSSL
+	SM3_CTX sm3_ctx;
+#endif
+
+	/**
+	 * Key (padded to block size)
+	 */
+	uint8_t key[SM3_BLOCK_SIZE];
+
+	/**
+	 * K XOR ipad (for inner hash)
+	 */
+	uint8_t ipad_key[SM3_BLOCK_SIZE];
+
+	/**
+	 * K XOR opad (for outer hash)
+	 */
+	uint8_t opad_key[SM3_BLOCK_SIZE];
+};
+
+/**
+ * Compute HMAC-SM3 signature
+ */
+static bool compute_hmac_sm3(private_hmac_sm3_signer_t *this,
+							 chunk_t data, uint8_t *mac)
+{
+#ifdef HAVE_GMSSL
+	uint8_t inner_hash[SM3_DIGEST_SIZE];
+	int i;
+
+	/* Inner hash: H(K XOR ipad || data) */
+	sm3_init(&this->sm3_ctx);
+	for (i = 0; i < SM3_BLOCK_SIZE; i++)
+	{
+		this->ipad_key[i] = this->key[i] ^ 0x36;
+	}
+	sm3_update(&this->sm3_ctx, this->ipad_key, SM3_BLOCK_SIZE);
+	sm3_update(&this->sm3_ctx, data.ptr, data.len);
+	sm3_finish(&this->sm3_ctx, inner_hash);
+
+	/* Outer hash: H(K XOR opad || inner_hash) */
+	sm3_init(&this->sm3_ctx);
+	for (i = 0; i < SM3_BLOCK_SIZE; i++)
+	{
+		this->opad_key[i] = this->key[i] ^ 0x5c;
+	}
+	sm3_update(&this->sm3_ctx, this->opad_key, SM3_BLOCK_SIZE);
+	sm3_update(&this->sm3_ctx, inner_hash, SM3_DIGEST_SIZE);
+	sm3_finish(&this->sm3_ctx, mac);
+
+	/* Clear sensitive data */
+	memwipe(inner_hash, sizeof(inner_hash));
+	memwipe(this->ipad_key, SM3_BLOCK_SIZE);
+	memwipe(this->opad_key, SM3_BLOCK_SIZE);
+
+	return TRUE;
+#else
+	return FALSE;
+#endif
+}
+
+METHOD(signer_t, get_signature, bool,
+	private_hmac_sm3_signer_t *this, chunk_t data, uint8_t *buffer)
+{
+	uint8_t full_mac[SM3_DIGEST_SIZE];
+
+	if (!compute_hmac_sm3(this, data, full_mac))
+	{
+		return FALSE;
+	}
+
+	/* Truncate to configured length */
+	memcpy(buffer, full_mac, this->truncation);
+	memwipe(full_mac, sizeof(full_mac));
+
+	return TRUE;
+}
+
+METHOD(signer_t, allocate_signature, bool,
+	private_hmac_sm3_signer_t *this, chunk_t data, chunk_t *signature)
+{
+	*signature = chunk_alloc(this->truncation);
+	return get_signature(this, data, signature->ptr);
+}
+
+METHOD(signer_t, verify_signature, bool,
+	private_hmac_sm3_signer_t *this, chunk_t data, chunk_t signature)
+{
+	uint8_t computed[SM3_DIGEST_SIZE];
+	bool equal;
+
+	if (signature.len != this->truncation)
+	{
+		return FALSE;
+	}
+
+	if (!compute_hmac_sm3(this, data, computed))
+	{
+		return FALSE;
+	}
+
+	equal = memeq_const(signature.ptr, computed, this->truncation);
+	memwipe(computed, sizeof(computed));
+
+	return equal;
+}
+
+METHOD(signer_t, get_key_size, size_t,
+	private_hmac_sm3_signer_t *this)
+{
+	return SM3_DIGEST_SIZE;
+}
+
+METHOD(signer_t, get_block_size, size_t,
+	private_hmac_sm3_signer_t *this)
+{
+	return SM3_BLOCK_SIZE;
+}
+
+METHOD(signer_t, set_key, bool,
+	private_hmac_sm3_signer_t *this, chunk_t key)
+{
+#ifdef HAVE_GMSSL
+	uint8_t padded_key[SM3_BLOCK_SIZE];
+
+	memset(padded_key, 0, SM3_BLOCK_SIZE);
+
+	if (key.len > SM3_BLOCK_SIZE)
+	{
+		/* Hash key if too long */
+		SM3_CTX ctx;
+		sm3_init(&ctx);
+		sm3_update(&ctx, key.ptr, key.len);
+		sm3_finish(&ctx, padded_key);
+	}
+	else
+	{
+		memcpy(padded_key, key.ptr, key.len);
+	}
+
+	memcpy(this->key, padded_key, SM3_BLOCK_SIZE);
+	memwipe(padded_key, sizeof(padded_key));
+
+	return TRUE;
+#else
+	return FALSE;
+#endif
+}
+
+METHOD(signer_t, destroy, void,
+	private_hmac_sm3_signer_t *this)
+{
+	memwipe(this->key, SM3_BLOCK_SIZE);
+	memwipe(this->ipad_key, SM3_BLOCK_SIZE);
+	memwipe(this->opad_key, SM3_BLOCK_SIZE);
+	free(this);
+}
+
+/**
+ * Create HMAC-SM3 signer with specified truncation
+ */
+static private_hmac_sm3_signer_t *create_hmac_sm3(size_t truncation)
+{
+	private_hmac_sm3_signer_t *this;
+
+	INIT(this,
+		.public = {
+			.hmac128 = {
+				.signer_interface = {
+					.get_signature = _get_signature,
+					.allocate_signature = _allocate_signature,
+					.verify_signature = _verify_signature,
+					.get_key_size = _get_key_size,
+					.get_block_size = _get_block_size,
+					.set_key = _set_key,
+					.destroy = _destroy,
+				},
+			},
+		},
+		.truncation = truncation,
+	);
+
+	memset(this->key, 0, SM3_BLOCK_SIZE);
+
+	return this;
+}
+
+/**
+ * Create HMAC-SM3-128 signer (128-bit truncation)
+ */
+signer_t* gmalg_hmac_sm3_128_signer_create(integrity_algorithm_t algo)
+{
+	private_hmac_sm3_signer_t *this;
+
+	if (algo != AUTH_HMAC_SM3_128)
+	{
+		return NULL;
+	}
+
+	this = create_hmac_sm3(16);
+	return &this->public.hmac128.signer_interface;
+}
+
+/**
+ * Create HMAC-SM3-256 signer (256-bit, no truncation)
+ */
+signer_t* gmalg_hmac_sm3_256_signer_create(integrity_algorithm_t algo)
+{
+	private_hmac_sm3_signer_t *this;
+
+	if (algo != AUTH_HMAC_SM3_256)
+	{
+		return NULL;
+	}
+
+	this = create_hmac_sm3(32);
+	return &this->public.hmac256.signer_interface;
+}
