+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_plugin.h - Chinese National Cryptographic Algorithm Plugin Header
+ */
+
+#ifndef GMALG_PLUGIN_H_
+#define GMALG_PLUGIN_H_
+
+#include <plugins/plugin.h>
+#include <crypto/hashers/hasher.h>
+#include <crypto/crypters/crypter.h>
+
+/* GM/T 0004-2012 SM3 Hash Algorithm (256-bit) */
+#define HASH_SM3		1032  /* SM3 Hash Algorithm */
+
+/* GM/T 0002-2012 SM4 Block Cipher */
+#define ENCR_SM4_ECB	1040  /* SM4 ECB mode */
+#define ENCR_SM4_CBC	1041  /* SM4 CBC mode */
+#define ENCR_SM4_CTR	1042  /* SM4 CTR mode */
+
+/* GM/T 0003-2012 SM2 Signature Algorithm (integrity) */
+#define AUTH_SM2		1050  /* SM2 Signature (64 bytes) */
+
+/* GM/T 0003-2012 SM2 Key Exchange */
+#define KE_SM2			1051  /* SM2 Key Exchange */
+
+/* PRF using SM3 */
+#define PRF_SM3			1052  /* PRF with SM3 */
+
+typedef struct gmalg_plugin_t gmalg_plugin_t;
+
+struct gmalg_plugin_t {
+
+	/**
+	 * Implements plugin interface
+	 */
+	plugin_t plugin;
+};
+
+/**
+ * gmalg_plugin_create - Create the gmalg plugin instance
+ *
+ * Returns the plugin instance
+ */
+plugin_t *gmalg_plugin_create(void);
+
+#endif /* GMALG_PLUGIN_H_ */
diff --git a/src/libstrongswan/plugins/gmalg/gmalg_signer.c b/src/libstrongswan/plugins/gmalg/gmalg_signer.c
new file mode 100644
index 0000000000..ab7e8c5582
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_signer.c
@@ -0,0 +1,265 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_signer.c - SM2 Signature Algorithm Implementation
+ */
+
+#include "gmalg_signer.h"
+
+#include <library.h>
+#include <crypto/signers/signer.h>
+#include <utils/debug.h>
+#ifdef HAVE_GMSSL
+#include <gmssl/sm2.h>
+#include <gmssl/sm2_z256.h>
+#include <gmssl/sm3.h>
+#endif
+
+#define GMALG_SM2_PRIV_KEY_SIZE 32
+#define GMALG_SM2_PUB_KEY_SIZE 65
+#define SM2_SIG_MAX_SIZE 72  /* DER encoded signature max size */
+
+typedef struct private_gmalg_sm2_signer_t private_gmalg_sm2_signer_t;
+
+/**
+ * private data of SM2 signer
+ */
+struct private_gmalg_sm2_signer_t {
+
+	/**
+	 * public signer interface
+	 */
+	gmalg_sm2_signer_t public;
+
+	/**
+	 * SM2 key context
+	 */
+	SM2_KEY sm2_key;
+
+	/**
+	 * Private key flag
+	 */
+	bool has_private_key;
+
+	/**
+	 * Key size
+	 */
+	size_t key_size;
+};
+
+/**
+ * get_signature function
+ */
+METHOD(signer_t, get_signature, bool,
+	private_gmalg_sm2_signer_t *this, chunk_t data, uint8_t *buffer)
+{
+#ifdef HAVE_GMSSL
+	SM3_CTX ctx;
+	uint8_t dgst[32];
+	size_t siglen = SM2_SIG_MAX_SIZE;
+
+	if (!this->has_private_key)
+	{
+		return FALSE;
+	}
+
+	/* SM3 hash of data */
+	sm3_init(&ctx);
+	sm3_update(&ctx, data.ptr, data.len);
+	sm3_finish(&ctx, dgst);
+
+	/* SM2 signature (DER encoded, 70-72 bytes) */
+	if (sm2_sign(&this->sm2_key, dgst, buffer, &siglen) != 1)
+	{
+		return FALSE;
+	}
+
+	return TRUE;
+#else
+	return FALSE;
+#endif
+}
+
+/**
+ * allocate_signature function
+ */
+METHOD(signer_t, allocate_signature, bool,
+	private_gmalg_sm2_signer_t *this, chunk_t data, chunk_t *signature)
+{
+#ifdef HAVE_GMSSL
+	SM3_CTX ctx;
+	uint8_t dgst[32];
+
+	if (!this->has_private_key)
+	{
+		return FALSE;
+	}
+
+	/* Allocate signature buffer (DER encoded, max 72 bytes) */
+	*signature = chunk_alloc(SM2_SIG_MAX_SIZE);
+
+	/* SM3 hash of data */
+	sm3_init(&ctx);
+	sm3_update(&ctx, data.ptr, data.len);
+	sm3_finish(&ctx, dgst);
+
+	/* SM2 signature (DER encoded) */
+	if (sm2_sign(&this->sm2_key, dgst, signature->ptr, &signature->len) != 1)
+	{
+		chunk_free(signature);
+		return FALSE;
+	}
+
+	return TRUE;
+#else
+	return FALSE;
+#endif
+}
+
+/**
+ * verify_signature function
+ */
+METHOD(signer_t, verify_signature, bool,
+	private_gmalg_sm2_signer_t *this, chunk_t data, chunk_t signature)
+{
+#ifdef HAVE_GMSSL
+	SM3_CTX ctx;
+	uint8_t dgst[32];
+	size_t actual_len;
+
+	/* SM3 hash of data */
+	sm3_init(&ctx);
+	sm3_update(&ctx, data.ptr, data.len);
+	sm3_finish(&ctx, dgst);
+
+	/* DER signature format: 30 [len] [content] */
+	/* Calculate actual length from DER encoding */
+	if (signature.len < 2)
+	{
+		return FALSE;
+	}
+	/* SEQUENCE tag (0x30) + length byte + content length */
+	actual_len = 2 + signature.ptr[1];
+	if (actual_len > signature.len)
+	{
+		actual_len = signature.len;
+	}
+
+	/* SM2 signature verification with actual DER length */
+	return sm2_verify(&this->sm2_key, dgst, signature.ptr, actual_len) == 1;
+#else
+	return FALSE;
+#endif
+}
+
+/**
+ * get_block_size function (signature size)
+ */
+METHOD(signer_t, get_block_size, size_t,
+	private_gmalg_sm2_signer_t *this)
+{
+	return SM2_SIG_MAX_SIZE;  /* DER encoded signature */
+}
+
+/**
+ * get_key_size function
+ */
+METHOD(signer_t, get_key_size, size_t,
+	private_gmalg_sm2_signer_t *this)
+{
+	return this->key_size;
+}
+
+/**
+ * set_key function
+ */
+METHOD(signer_t, set_key, bool,
+	private_gmalg_sm2_signer_t *this, chunk_t key)
+{
+#ifdef HAVE_GMSSL
+	const uint8_t *ptr = key.ptr;
+	size_t len = key.len;
+
+	/* Try different key formats */
+
+	/* Format 1: DER encoded private key info */
+	if (sm2_private_key_info_from_der(&this->sm2_key, NULL, NULL, &ptr, &len) == 1)
+	{
+		this->has_private_key = TRUE;
+		this->key_size = GMALG_SM2_PRIV_KEY_SIZE;
+		return TRUE;
+	}
+
+	/* Format 2: DER encoded public key info */
+	ptr = key.ptr;
+	len = key.len;
+	if (sm2_public_key_info_from_der(&this->sm2_key, &ptr, &len) == 1)
+	{
+		this->has_private_key = FALSE;
+		this->key_size = GMALG_SM2_PUB_KEY_SIZE;
+		return TRUE;
+	}
+
+	/* Format 3: Raw private key (32 bytes) */
+	if (len == GMALG_SM2_PRIV_KEY_SIZE)
+	{
+		if (sm2_key_set_private_key(&this->sm2_key, (const uint64_t*)ptr) == 1)
+		{
+			/* Compute public key from private key for verification */
+			sm2_z256_point_mul_generator(&this->sm2_key.public_key,
+										 this->sm2_key.private_key);
+			this->has_private_key = TRUE;
+			this->key_size = GMALG_SM2_PRIV_KEY_SIZE;
+			return TRUE;
+		}
+	}
+
+	DBG1(DBG_LIB, "SM2: failed to set key, len: %B", key.len);
+
+	return FALSE;
+#else
+	return FALSE;
+#endif
+}
+
+/**
+ * destroy function
+ */
+METHOD(signer_t, destroy, void,
+	private_gmalg_sm2_signer_t *this)
+{
+	free(this);
+}
+
+/*
+ * see header file
+ */
+signer_t* gmalg_sm2_signer_create(integrity_algorithm_t algo)
+{
+#ifdef HAVE_GMSSL
+	private_gmalg_sm2_signer_t *this;
+
+	INIT(this,
+		.public = {
+			.signer_interface = {
+				.get_signature = _get_signature,
+				.allocate_signature = _allocate_signature,
+				.verify_signature = _verify_signature,
+				.get_block_size = _get_block_size,
+				.get_key_size = _get_key_size,
+				.set_key = _set_key,
+				.destroy = _destroy,
+			},
+		},
+		.has_private_key = FALSE,
+		.key_size = GMALG_SM2_PRIV_KEY_SIZE,
+	);
+
+	/* Initialize SM2 key context to zeros */
+	memset(&this->sm2_key, 0, sizeof(SM2_KEY));
+
+	return &this->public.signer_interface;
+#else
+	return NULL;
+#endif
+}
diff --git a/src/libstrongswan/plugins/gmalg/gmalg_signer.h b/src/libstrongswan/plugins/gmalg/gmalg_signer.h
new file mode 100644
index 0000000000..877d1fb436
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_signer.h
@@ -0,0 +1,34 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_signer.h - SM2 Signature Algorithm Header
+ */
+
+#ifndef GMALG_SIGNER_H_
+#define GMALG_SIGNER_H_
+
+#include <crypto/signers/signer.h>
+#include "gmalg_plugin.h"
+
+/**
+ * SM2 Signer
