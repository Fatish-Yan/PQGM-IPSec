+/**
+ * Create ML-DSA public key directly from raw data.
+ * This is a helper function to bypass the builder system.
+ */
+mldsa_public_key_t *mldsa_public_key_create(chunk_t data)
+{
+	private_mldsa_public_key_t *this;
+
+	if (data.len != MLDSA65_PUBLIC_KEY_BYTES)
