+	key_len = key_enc.len;
+	if (sm2_private_key_info_from_der(&sm2_my_key, NULL, NULL, &key_ptr, &key_len) != 1)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to parse SM2 private key from DER");
+		chunk_free(&key_enc);
