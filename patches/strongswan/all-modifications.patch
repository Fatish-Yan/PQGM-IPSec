diff --git a/src/libstrongswan/plugins/mldsa/mldsa_public_key.c b/src/libstrongswan/plugins/mldsa/mldsa_public_key.c
new file mode 100644
index 0000000000..9058b675fd
--- /dev/null
+++ b/src/libstrongswan/plugins/mldsa/mldsa_public_key.c
@@ -0,0 +1,379 @@
+/*
+ * Copyright (C) 2026 PQGM-IPSec Project
+ *
+ * This program is free software; you can redistribute it and/or modify it
+ * under the terms of the GNU General Public License as published by the
+ * Free Software Foundation; either version 2 of the License, or (at your
+ * option) any later version.  See <http://www.fsf.org/copyleft/gpl.txt>.
+ *
+ * This program is distributed in the hope that it will be useful, but
+ * WITHOUT ANY WARRANTY; without even the implied warranty of MERCHANTABILITY
+ * or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU General Public License
+ * for more details.
+ */
+
+#include "mldsa_public_key.h"
+
+#include <asn1/asn1.h>
+#include <asn1/asn1_parser.h>
+#include <credentials/cred_encoding.h>
+#include <crypto/hashers/hasher.h>
+#include <utils/debug.h>
+
+#include <oqs/oqs.h>
+
+/* ML-DSA-65 constants from FIPS 204 */
+#define MLDSA65_PUBLIC_KEY_BYTES  1952
+#define MLDSA65_SIGNATURE_BYTES   3309
+
+/* ML-DSA public key extension OID: 1.3.6.1.4.1.99999.1.2 */
+#define MLDSA_OID_LEN 12
+static const uint8_t MLDSA_OID_DER[] = {0x06, 0x0A, 0x2B, 0x06, 0x01, 0x04, 0x01, 0x86, 0x8D, 0x1F, 0x01, 0x02};
+
+typedef struct private_mldsa_public_key_t private_mldsa_public_key_t;
+
+/**
+ * Private data structure.
+ */
+struct private_mldsa_public_key_t {
+
+	/**
+	 * Public interface.
+	 */
+	mldsa_public_key_t public;
+
+	/**
+	 * ML-DSA-65 public key (1952 bytes).
+	 */
+	chunk_t pubkey;
+
+	/**
+	 * Reference counter.
+	 */
+	refcount_t ref;
+};
+
+METHOD(public_key_t, get_type, key_type_t,
+	private_mldsa_public_key_t *this)
+{
+	return KEY_MLDSA65;
+}
+
+METHOD(public_key_t, verify, bool,
+	private_mldsa_public_key_t *this, signature_scheme_t scheme,
+	void *params, chunk_t data, chunk_t signature)
+{
+	OQS_SIG *sig_ctx;
+
+	if (scheme != SIGN_MLDSA65)
+	{
+		DBG1(DBG_LIB, "ML-DSA: signature scheme %N not supported, expected SIGN_MLDSA65",
+			 signature_scheme_names, scheme);
+		return FALSE;
+	}
+
+	if (signature.len != MLDSA65_SIGNATURE_BYTES)
+	{
+		DBG1(DBG_LIB, "ML-DSA: invalid signature length %zu, expected %d",
+			 signature.len, MLDSA65_SIGNATURE_BYTES);
+		return FALSE;
+	}
+
+	if (this->pubkey.len != MLDSA65_PUBLIC_KEY_BYTES)
+	{
+		DBG1(DBG_LIB, "ML-DSA: invalid public key length %zu, expected %d",
+			 this->pubkey.len, MLDSA65_PUBLIC_KEY_BYTES);
+		return FALSE;
+	}
+
+	sig_ctx = OQS_SIG_new(OQS_SIG_alg_ml_dsa_65);
+	if (!sig_ctx)
+	{
+		DBG1(DBG_LIB, "ML-DSA: failed to create OQS signature context");
+		return FALSE;
+	}
+
+	if (OQS_SIG_verify(sig_ctx, data.ptr, data.len,
+					   signature.ptr, signature.len,
+					   this->pubkey.ptr) != OQS_SUCCESS)
+	{
+		DBG1(DBG_LIB, "ML-DSA: signature verification failed");
+		OQS_SIG_free(sig_ctx);
+		return FALSE;
+	}
+
+	OQS_SIG_free(sig_ctx);
+	DBG1(DBG_LIB, "ML-DSA: signature verification successful");
+	return TRUE;
+}
+
+METHOD(public_key_t, encrypt_, bool,
+	private_mldsa_public_key_t *this, encryption_scheme_t scheme,
+	void *params, chunk_t plain, chunk_t *crypto)
+{
+	DBG1(DBG_LIB, "ML-DSA: encryption scheme %N not supported",
+		 encryption_scheme_names, scheme);
+	return FALSE;
+}
+
+METHOD(public_key_t, get_keysize, int,
+	private_mldsa_public_key_t *this)
+{
+	/* Return key strength in bits */
+	return 8 * MLDSA65_PUBLIC_KEY_BYTES;
+}
+
+METHOD(public_key_t, get_encoding, bool,
+	private_mldsa_public_key_t *this, cred_encoding_type_t type,
+	chunk_t *encoding)
+{
+	/* For now, just return the raw public key */
+	if (type == PUBKEY_SPKI_ASN1_DER)
+	{
+		/* TODO: Implement proper SubjectPublicKeyInfo encoding */
+		*encoding = chunk_clone(this->pubkey);
+		return TRUE;
+	}
+
+	DBG1(DBG_LIB, "ML-DSA: encoding type %d not supported", type);
+	return FALSE;
+}
+
+METHOD(public_key_t, get_fingerprint, bool,
+	private_mldsa_public_key_t *this, cred_encoding_type_t type,
+	chunk_t *fp)
+{
+	hasher_t *hasher;
+
+	if (lib->encoding->get_cache(lib->encoding, type, this, fp))
+	{
+		return TRUE;
+	}
+
+	if (type == KEYID_PUBKEY_SHA1)
+	{
+		hasher = lib->crypto->create_hasher(lib->crypto, HASH_SHA1);
+		if (!hasher)
+		{
+			DBG1(DBG_LIB, "ML-DSA: SHA1 hasher not available");
+			return FALSE;
+		}
+		if (!hasher->allocate_hash(hasher, this->pubkey, fp))
+		{
+			hasher->destroy(hasher);
+			return FALSE;
+		}
+		hasher->destroy(hasher);
+		lib->encoding->cache(lib->encoding, type, this, fp);
+		return TRUE;
+	}
+
+	return FALSE;
+}
+
+METHOD(public_key_t, has_fingerprint, bool,
+	private_mldsa_public_key_t *this, chunk_t fp)
+{
+	chunk_t computed;
+
+	if (get_fingerprint(this, KEYID_PUBKEY_SHA1, &computed))
+	{
+		bool match = chunk_equals_const(computed, fp);
+		chunk_free(&computed);
+		return match;
+	}
+	return FALSE;
+}
+
+METHOD(public_key_t, equals, bool,
+	private_mldsa_public_key_t *this, public_key_t *other)
+{
+	chunk_t other_key;
+
+	if (other->get_type(other) != KEY_MLDSA65)
+	{
+		return FALSE;
+	}
+
+	if (!other->get_encoding(other, PUBKEY_SPKI_ASN1_DER, &other_key))
+	{
+		return FALSE;
+	}
+
+	bool equal = chunk_equals(this->pubkey, other_key);
+	chunk_free(&other_key);
+	return equal;
+}
+
+METHOD(public_key_t, get_ref, public_key_t*,
+	private_mldsa_public_key_t *this)
+{
+	ref_get(&this->ref);
+	return &this->public.key;
+}
+
+METHOD(public_key_t, destroy, void,
+	private_mldsa_public_key_t *this)
+{
+	if (ref_put(&this->ref))
+	{
+		lib->encoding->clear_cache(lib->encoding, this);
+		chunk_clear(&this->pubkey);
+		free(this);
+	}
+}
+
+/**
+ * Extract ML-DSA public key from X.509 certificate extension.
+ * Uses simple memory search to find the OID in the certificate.
+ */
+bool mldsa_extract_pubkey_from_cert(chunk_t cert_der, chunk_t *pubkey)
+{
+	size_t i;
+	uint8_t *p;
+	size_t remaining;
+
+	*pubkey = chunk_empty;
+
+	/* Search for the ML-DSA OID in the certificate */
+	for (i = 0; i + MLDSA_OID_LEN < cert_der.len; i++)
+	{
+		if (memeq(cert_der.ptr + i, MLDSA_OID_DER, MLDSA_OID_LEN))
+		{
+			DBG1(DBG_LIB, "ML-DSA: found ML-DSA extension OID at offset %zu", i);
+
+			/* OID found, now find the OCTET STRING containing the public key */
+			p = cert_der.ptr + i + MLDSA_OID_LEN;
+			remaining = cert_der.len - i - MLDSA_OID_LEN;
+
+			/* Skip any ASN.1 framing to find the OCTET STRING */
+			/* Typical structure: OID, OCTET STRING tag (0x04), length, data */
+			while (remaining > 2)
+			{
+				if (*p == 0x04)
+				{
+					/* OCTET STRING found */
+					size_t len;
+					p++;
+					remaining--;
+
+					/* Parse length (assuming short form for 1952 bytes) */
+					if (*p < 0x80)
+					{
+						len = *p;
+						p++;
+						remaining--;
+					}
+					else if (*p == 0x82)
+					{
+						/* Long form, 2 bytes length */
+						if (remaining < 3) break;
+						len = (p[1] << 8) | p[2];
+						p += 3;
+						remaining -= 3;
+					}
+					else
+					{
+						p++;
+						remaining--;
+						continue;
+					}
+
+					if (len >= MLDSA65_PUBLIC_KEY_BYTES && remaining >= MLDSA65_PUBLIC_KEY_BYTES)
+					{
+						*pubkey = chunk_clone(chunk_create(p, MLDSA65_PUBLIC_KEY_BYTES));
+						DBG1(DBG_LIB, "ML-DSA: extracted %zu byte public key from certificate", pubkey->len);
+						return TRUE;
+					}
+				}
+				p++;
+				remaining--;
+			}
+		}
+	}
+
+	DBG1(DBG_LIB, "ML-DSA: could not extract public key from certificate extension");
+	return FALSE;
+}
+
+/**
+ * See header.
+ */
+mldsa_public_key_t *mldsa_public_key_load(key_type_t type, va_list args)
+{
+	private_mldsa_public_key_t *this;
+	chunk_t blob = chunk_empty;
+
+	if (type != KEY_MLDSA65 && type != KEY_ANY)
+	{
+		return NULL;
+	}
+
+	while (TRUE)
+	{
+		switch (va_arg(args, builder_part_t))
+		{
+			case BUILD_BLOB:
+			case BUILD_BLOB_PEM:
+				blob = va_arg(args, chunk_t);
+				continue;
+			case BUILD_END:
+				break;
+			default:
+				return NULL;
+		}
+		break;
+	}
+
+	/* Check if this is a certificate (large blob) - try to extract ML-DSA key */
+	if (blob.len > MLDSA65_PUBLIC_KEY_BYTES * 2)
+	{
+		chunk_t extracted;
+		if (mldsa_extract_pubkey_from_cert(blob, &extracted))
+		{
+			blob = extracted;
+		}
+		else
+		{
+			/* Try using blob directly as public key */
+			if (blob.len != MLDSA65_PUBLIC_KEY_BYTES)
+			{
+				DBG1(DBG_LIB, "ML-DSA: invalid public key size %zu", blob.len);
+				return NULL;
+			}
+			blob = chunk_clone(blob);
+		}
+	}
+	else if (blob.len == MLDSA65_PUBLIC_KEY_BYTES)
+	{
+		blob = chunk_clone(blob);
+	}
+	else
+	{
+		DBG1(DBG_LIB, "ML-DSA: invalid public key size %zu, expected %d",
+			 blob.len, MLDSA65_PUBLIC_KEY_BYTES);
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.key = {
+				.get_type = _get_type,
+				.verify = _verify,
+				.encrypt = _encrypt_,
+				.equals = _equals,
+				.get_keysize = _get_keysize,
+				.get_fingerprint = _get_fingerprint,
+				.has_fingerprint = _has_fingerprint,
+				.get_encoding = _get_encoding,
+				.get_ref = _get_ref,
+				.destroy = _destroy,
+			},
+		},
+		.pubkey = blob,
+		.ref = 1,
+	);
+
+	DBG1(DBG_LIB, "ML-DSA: loaded public key successfully (%zu bytes)", this->pubkey.len);
+	return &this->public;
+}
