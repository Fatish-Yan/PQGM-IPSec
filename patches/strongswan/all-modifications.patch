+
+/* OID DER 编码: 06 0A 2B 06 01 04 01 86 8D 1F 01 02 */
+static const uint8_t mldsa_oid[] = {0x06, 0x0A, 0x2B, 0x06, 0x01, 0x04, 0x01, 0x86, 0x8D, 0x1F, 0x01, 0x02};
