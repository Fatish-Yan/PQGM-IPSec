+/**
+ * Inject IDs into SM2-KEM instance if applicable
+ *
+ * Uses dlopen/dlsym to find plugin functions at runtime since the gmalg plugin
+ * is loaded dynamically after libcharon.
+ */
+static void inject_sm2kem_ids(private_ike_init_t *this, key_exchange_t *ke,
+							  key_exchange_method_t method)
+{
+	typedef void (*set_peer_id_fn)(key_exchange_t *, identification_t *);
+	typedef void (*set_my_id_fn)(key_exchange_t *, identification_t *);
+	typedef void (*set_role_fn)(key_exchange_t *, bool);
+
+	static set_peer_id_fn set_peer_id = NULL;
+	static set_my_id_fn set_my_id = NULL;
+	static set_role_fn set_role = NULL;
+	static bool initialized = FALSE;
+
+	if (method != KE_SM2)
+	{
+		return;
+	}
+
+	/* Resolve symbols once */
+	if (!initialized)
+	{
+		void *handle;
+
+		/* Try to load the gmalg plugin to get its symbols */
+		handle = dlopen("libstrongswan-gmalg.so", RTLD_LAZY | RTLD_NOLOAD);
+		if (!handle)
+		{
+			/* Plugin not loaded yet, try loading from install path */
+			handle = dlopen("/usr/local/lib/ipsec/plugins/libstrongswan-gmalg.so",
+							RTLD_LAZY | RTLD_GLOBAL);
+		}
+
+		if (handle)
+		{
+			set_peer_id = (set_peer_id_fn)dlsym(handle, "gmalg_sm2_ke_set_peer_id");
+			set_my_id = (set_my_id_fn)dlsym(handle, "gmalg_sm2_ke_set_my_id");
+			set_role = (set_role_fn)dlsym(handle, "gmalg_sm2_ke_set_role");
+
+			if (set_peer_id && set_my_id && set_role)
+			{
+				DBG1(DBG_IKE, "SM2-KEM: gmalg plugin functions found");
+			}
+			else
+			{
+				DBG1(DBG_IKE, "SM2-KEM: gmalg plugin loaded but functions not found");
+				dlclose(handle);
+			}
+		}
+		else
+		{
+			DBG1(DBG_IKE, "SM2-KEM: gmalg plugin not found: %s", dlerror());
+		}
+		initialized = TRUE;
+	}
+
+	if (set_peer_id && set_my_id && set_role)
+	{
+		identification_t *peer_id, *my_id;
+
+		peer_id = this->ike_sa->get_other_id(this->ike_sa);
+		my_id = this->ike_sa->get_my_id(this->ike_sa);
+
+		if (peer_id && my_id)
+		{
+			DBG1(DBG_IKE, "SM2-KEM: injecting IDs - peer=%Y, my=%Y",
+				 peer_id, my_id);
+			set_peer_id(ke, peer_id);
+			set_my_id(ke, my_id);
+			set_role(ke, this->initiator);
+		}
+		else
+		{
+			DBG1(DBG_IKE, "SM2-KEM: failed to get IDs for injection");
+		}
+	}
+}
