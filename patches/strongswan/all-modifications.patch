-
-	/* Debug: print my public key (should match what Initiator used to encrypt) */
-	export_sm2_public_key(&this->my_key, my_pubkey);
-	fprintf(stderr, "DEBUG responder_decaps: my_pubkey = ");
-	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", my_pubkey[i]);
-	fprintf(stderr, "...\n");
-	fflush(stderr);
 
 	/* Decrypt ciphertext using our private key */
 	ptlen = sizeof(plaintext);
@@ -439,15 +414,11 @@ static bool responder_decaps(private_key_exchange_t *this, chunk_t ciphertext)
 						  ciphertext.ptr, ciphertext.len,
 						  plaintext, &ptlen))
 	{
-		fprintf(stderr, "DEBUG: sm2_decrypt_data failed\n");
-		fflush(stderr);
 		return FALSE;
 	}
 
 	if (ptlen != SM2_KEM_RANDOM_SIZE)
 	{
-		fprintf(stderr, "DEBUG: ptlen=%zu != %d\n", ptlen, SM2_KEM_RANDOM_SIZE);
-		fflush(stderr);
 		return FALSE;
 	}
 
@@ -455,12 +426,6 @@ static bool responder_decaps(private_key_exchange_t *this, chunk_t ciphertext)
 	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
 	memcpy(this->peer_random.ptr, plaintext, ptlen);
 
-	/* Debug: print decrypted value */
-	fprintf(stderr, "DEBUG responder_decaps: peer_random (r_i) = ");
-	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", this->peer_random.ptr[i]);
-	fprintf(stderr, "...\n");
-	fflush(stderr);
-
 	return TRUE;
 }
 
@@ -507,9 +472,7 @@ static bool compute_shared_secret(private_key_exchange_t *this)
 {
 	if (!this->my_random.ptr || !this->peer_random.ptr)
