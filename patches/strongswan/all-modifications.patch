+	 *   Round 2: ML-KEM
+	 */
+	int intermediate_round;
 };
 
 /**
@@ -903,6 +912,20 @@ METHOD(task_t, build_i_multi_ke, status_t,
 
 	message->set_exchange_type(message, exchange_type_multi_ke(this));
 
+	/* PQ-GM-IKEv2 5-RTT: First IKE_INTERMEDIATE is for certificates only (no KE)
+	 * IKE_INTERMEDIATE #0: Certificates only
+	 * IKE_INTERMEDIATE #1: SM2-KEM
+	 * IKE_INTERMEDIATE #2: ML-KEM
+	 */
+	if (this->intermediate_round == 0)
+	{
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: IKE_INTERMEDIATE #%d - certificates only, skipping KE",
+			 this->intermediate_round);
