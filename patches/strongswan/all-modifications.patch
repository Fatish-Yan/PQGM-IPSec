+#ifndef MLDSA_PUBLIC_KEY_H_
+#define MLDSA_PUBLIC_KEY_H_
+
+#include <credentials/keys/public_key.h>
+
+typedef struct mldsa_public_key_t mldsa_public_key_t;
+
+/**
+ * ML-DSA-65 public key implementation.
+ */
+struct mldsa_public_key_t {
+
+	/**
+	 * Implements public_key_t interface.
+	 */
+	public_key_t key;
+};
+
+/**
+ * Load an ML-DSA-65 public key.
+ *
+ * Accepts BUILD_BLOB for raw public key data (1952 bytes).
+ *
+ * @param type		key type to load (KEY_MLDSA65 or KEY_ANY)
+ * @param args		builder_part_t arguments
+ * @return			loaded key, NULL on failure
+ */
+mldsa_public_key_t *mldsa_public_key_load(key_type_t type, va_list args);
+
+/**
+ * Extract ML-DSA public key from hybrid certificate extension.
+ *
+ * @param cert_der	DER-encoded X.509 certificate
+ * @param pubkey	allocated ML-DSA public key (1952 bytes)
+ * @return			TRUE if extraction successful
+ */
+bool mldsa_extract_pubkey_from_cert(chunk_t cert_der, chunk_t *pubkey);
+
