+private_key_t *mldsa_private_key_load(key_type_t type, va_list args)
+{
+	chunk_t blob = chunk_empty;
+	char *file = NULL;
+	chunk_t data;
+	private_key_t *key = NULL;
+
+	/* Parse arguments */
+	while (TRUE)
+	{
+		switch (va_arg(args, builder_part_t))
+		{
+			case BUILD_BLOB:
+				blob = va_arg(args, chunk_t);
+				continue;
+			case BUILD_FROM_FILE:
+				file = va_arg(args, char*);
+				continue;
+			case BUILD_END:
+				break;
+			default:
+				return NULL;
+		}
+		break;
+	}
+
+	/* Load from blob or file */
+	if (blob.len)
+	{
+		return mldsa_private_key_create(blob);
+	}
+	else if (file)
+	{
+		/* Try to load from file */
+		if (chunk_read_file(file, &data))
+		{
+			key = mldsa_private_key_create(data);
+			chunk_free(&data);
+		}
+	}
+
