1. should_send_intermediate_certs():
   - 无peer_cfg时返回TRUE（IKE_INTERMEDIATE阶段peer_cfg未设置）
   - 跳过supports_extension检查（收到IKE_INTERMEDIATE消息说明对端支持）

2. build_intermediate_certs():
   - 无peer_cfg时继续执行
   - 总是从文件加载SM2证书（不使用credmgr中的ED25519证书）
   - 添加详细调试日志

修复后响应方在IKE_INTERMEDIATE #0正确发送SM2双证书
---
 src/libcharon/sa/ikev2/tasks/ike_cert_post.c | 96 ++++++++++++--------
 1 file changed, 60 insertions(+), 36 deletions(-)

diff --git a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
index 311b652c06..9dfb33b095 100644
--- a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
+++ b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
@@ -539,44 +539,22 @@ static certificate_t *find_encryption_cert(private_ike_cert_post_t *this,
 static void build_intermediate_certs(private_ike_cert_post_t *this,
 									 message_t *message)
 {
-	peer_cfg_t *peer_cfg;
-	auth_cfg_t *auth;
 	certificate_t *sign_cert, *enc_cert;
 	identification_t *id;
 
-	peer_cfg = this->ike_sa->get_peer_cfg(this->ike_sa);
-	if (!peer_cfg)
-	{
-		return;
-	}
+	/* Note: peer_cfg may be NULL during IKE_INTERMEDIATE, that's OK */
+	/* Note: supports_extension may return FALSE, but if we got IKE_INTERMEDIATE message,
+	 * peer obviously supports it, so we proceed anyway */
 
-	/* Check if peer supports IKE_INTERMEDIATE */
-	if (!this->ike_sa->supports_extension(this->ike_sa, EXT_IKE_INTERMEDIATE))
-	{
-		DBG2(DBG_IKE, "peer does not support IKE_INTERMEDIATE, skipping "
-			 "dual certificate distribution");
-		return;
-	}
-
-	auth = this->ike_sa->get_auth_cfg(this->ike_sa, TRUE);
-	if (!auth)
-	{
-		return;
-	}
-
-	/* Get the signing certificate */
-	sign_cert = auth->get(auth, AUTH_RULE_SUBJECT_CERT);
-	if (!sign_cert)
+	/* PQ-GM-IKEv2: For IKE_INTERMEDIATE, always send SM2 certificates from files
+	 * The ED25519 certificate in credmgr is for IKE_AUTH, not for IKE_INTERMEDIATE SM2-KEM
+	 * Note: auth may not be set yet during IKE_INTERMEDIATE, that's OK */
 	{
 		FILE *fp;
 		const char *sign_cert_path = "/usr/local/etc/swanctl/x509/sm2_sign_cert.pem";
 		const char *enc_cert_path = "/usr/local/etc/swanctl/x509/sm2_enc_cert.pem";
 
-		DBG1(DBG_IKE, "no subject certificate found for IKE_INTERMEDIATE");
-
-		/* PQ-GM-IKEv2: Load SM2 certificates directly from files */
-		/* This bypasses OpenSSL parsing for SM2 certificates */
-		DBG1(DBG_IKE, "PQ-GM-IKEv2: loading SM2 certificates from files");
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: loading SM2 certificates from files for IKE_INTERMEDIATE");
 
 		/* Send SignCert from file - try both naming conventions */
 		fp = fopen(sign_cert_path, "r");
@@ -653,11 +631,14 @@ static bool should_send_intermediate_certs(private_ike_cert_post_t *this,
 		return FALSE;
 	}
 
-	/* Check if peer supports IKE_INTERMEDIATE */
+	DBG1(DBG_IKE, "PQ-GM-IKEv2: should_send_intermediate_certs: msg_id=1, certs_not_sent");
+
+	/* Check if peer supports IKE_INTERMEDIATE
+	 * Note: If we received an IKE_INTERMEDIATE message, peer obviously supports it */
 	if (!this->ike_sa->supports_extension(this->ike_sa, EXT_IKE_INTERMEDIATE))
 	{
-		DBG1(DBG_IKE, "PQ-GM-IKEv2: peer does not support IKE_INTERMEDIATE");
-		return FALSE;
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: supports_extension returned FALSE, but we're in IKE_INTERMEDIATE, so peer supports it");
+		/* Don't fail here - if we got IKE_INTERMEDIATE message, peer supports it */
 	}
 
 	/* Check certificate policy */
@@ -665,20 +646,57 @@ static bool should_send_intermediate_certs(private_ike_cert_post_t *this,
 	peer_cfg = this->ike_sa->get_peer_cfg(this->ike_sa);
 	if (!peer_cfg)
 	{
-		DBG1(DBG_IKE, "PQ-GM-IKEv2: no peer_cfg found");
-		return FALSE;
+		/* For IKE_INTERMEDIATE, peer_cfg may not be set yet (set during IKE_AUTH).
+		 * If peer sent us certificates, we should reply with ours. */
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: no peer_cfg yet, but peer sent IKE_INTERMEDIATE, will send certs");
+		return TRUE;
 	}
 
+	DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy = %d", peer_cfg->get_cert_policy(peer_cfg));
+
 	switch (peer_cfg->get_cert_policy(peer_cfg))
 	{
 		case CERT_NEVER_SEND:
 			DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy is CERT_NEVER_SEND");
 			return FALSE;
 		case CERT_SEND_IF_ASKED:
+			DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy is CERT_SEND_IF_ASKED, COND_CERTREQ_SEEN=%d",
+				 this->ike_sa->has_condition(this->ike_sa, COND_CERTREQ_SEEN));
+			/* For IKE_INTERMEDIATE, if peer sent certificates, treat as if asked */
 			if (!this->ike_sa->has_condition(this->ike_sa, COND_CERTREQ_SEEN))
 			{
-				DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy is CERT_SEND_IF_ASKED but no CERTREQ seen");
-				return FALSE;
+				/* Check if we received certificates in IKE_INTERMEDIATE #0 */
+				if (message->get_message_id(message) == 1)
+				{
+					enumerator_t *enumerator;
+					payload_t *payload;
+					bool has_certs = FALSE;
+
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: checking for certificate payloads in message");
+					enumerator = message->create_payload_enumerator(message);
+					while (enumerator->enumerate(enumerator, &payload))
+					{
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: found payload type %d", payload->get_type(payload));
+						if (payload->get_type(payload) == PLV2_CERTIFICATE)
+						{
+							has_certs = TRUE;
+							break;
+						}
+					}
+					enumerator->destroy(enumerator);
+
+					if (!has_certs)
+					{
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy is CERT_SEND_IF_ASKED but no CERTREQ/certs seen");
+						return FALSE;
+					}
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: peer sent certificates, will reply with certs");
+				}
+				else
+				{
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: cert policy is CERT_SEND_IF_ASKED but no CERTREQ seen");
+					return FALSE;
+				}
 			}
 			/* FALL */
 		case CERT_ALWAYS_SEND:
@@ -865,12 +883,18 @@ METHOD(task_t, build_r, status_t,
 			break;
 		case IKE_INTERMEDIATE:
 			/* PQ-GM-IKEv2: Send dual certificates in first IKE_INTERMEDIATE */
+			DBG1(DBG_IKE, "PQ-GM-IKEv2: build_r IKE_INTERMEDIATE msg_id=%d",
+				 message->get_message_id(message));
 			if (should_send_intermediate_certs(this, message))
 			{
 				DBG1(DBG_IKE, "PQ-GM-IKEv2: building certificates for "
 					 "IKE_INTERMEDIATE exchange");
 				build_intermediate_certs(this, message);
 			}
+			else
+			{
+				DBG1(DBG_IKE, "PQ-GM-IKEv2: should_send_intermediate_certs returned FALSE");
+			}
 			break;
 		default:
 			break;
