MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

1. ike_cert_post.c - process_sm2_certs():
   - 添加 x509_cert_check 检查证书 KeyUsage
   - 只提取 EncCert (keyEncipherment) 的公钥
   - 区分 SignCert 和 EncCert

2. gmalg_ke.c - 公钥获取优先级:
   - Priority 1: 全局变量 g_peer_sm2_pubkey (从IKE_INTERMEDIATE EncCert)
   - Priority 2: this->peer_enccert (直接设置)
   - Priority 3: credmgr 查找
   - Priority 4: 文件 fallback (deprecated)

3. gmalg_ke.c - 私钥获取优先级:
   - Priority 1: 全局变量 g_my_sm2_key
   - Priority 2: this->my_key
   - Priority 3: credmgr 查找
   - Priority 4: 文件 fallback (deprecated)

4. 性能优化:
   - 移除所有 fprintf(stderr, ...) 调试输出
   - 移除 fflush() 调用
---
 src/libcharon/sa/ikev2/tasks/ike_cert_post.c |  51 +++++++-
 src/libstrongswan/plugins/gmalg/gmalg_ke.c   | 130 +++++++------------
 2 files changed, 93 insertions(+), 88 deletions(-)

diff --git a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
index 9dfb33b095..32c3095ac4 100644
--- a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
+++ b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
@@ -733,7 +733,13 @@ METHOD(task_t, build_i, status_t,
 
 /**
  * Process received SM2 certificates in IKE_INTERMEDIATE
- * Extract SM2 public key from EncCert and store globally for SM2-KEM
+ * Extract SM2 public key from EncCert (not SignCert) and store globally for SM2-KEM
+ *
+ * SM2 dual certificate mechanism (GM/T 0009-2012):
+ * - SignCert: digitalSignature, for identity authentication
+ * - EncCert: keyEncipherment, for SM2-KEM key encapsulation
+ *
+ * Only extract public key from EncCert for SM2-KEM usage.
  */
 static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 {
@@ -744,12 +750,15 @@ static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 	chunk_t cert_data = chunk_empty;
 	X509_KEY x509_key;
 	SM2_KEY sm2_pubkey;
+	int path_len;
 
 	typedef void (*set_peer_pubkey_fn)(const void *);
 	typedef int (*x509_get_pubkey_fn)(const uint8_t *, size_t, void *);
+	typedef int (*x509_cert_check_fn)(const uint8_t *, size_t, int, int *);
 
 	static set_peer_pubkey_fn set_global_peer_pubkey = NULL;
 	static x509_get_pubkey_fn x509_cert_get_pubkey = NULL;
+	static x509_cert_check_fn x509_cert_check = NULL;
 	static bool symbols_initialized = FALSE;
 
 	/* Resolve symbols once */
@@ -766,6 +775,8 @@ static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 		{
 			x509_cert_get_pubkey = (x509_get_pubkey_fn)dlsym(gmssl_handle,
 											"x509_cert_get_subject_public_key");
+			x509_cert_check = (x509_cert_check_fn)dlsym(gmssl_handle,
+											"x509_cert_check");
 		}
 
 		/* Load gmalg plugin */
@@ -811,11 +822,37 @@ static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 			if (cert_data.len > 0)
 			{
 				DBG1(DBG_IKE, "PQ-GM-IKEv2: received certificate (%zu bytes), "
-					 "trying to extract SM2 public key", cert_data.len);
+					 "checking if it's an SM2 EncCert", cert_data.len);
 
 				memset(&x509_key, 0, sizeof(X509_KEY));
 
-				/* Extract public key from certificate using GmSSL */
+				/* First check if this is an encryption certificate (keyEncipherment)
+				 * SM2 dual certificate mechanism:
+				 * - SignCert: digitalSignature (for authentication)
+				 * - EncCert: keyEncipherment (for SM2-KEM)
+				 * We only want EncCert for SM2-KEM
+				 */
+				if (x509_cert_check)
+				{
+					int is_key_encipher = 0;
+					/* X509_cert_server_key_encipher = 2, X509_cert_client_key_encipher = 3 */
+					if (x509_cert_check(cert_data.ptr, cert_data.len, 2, &path_len) == 1 ||
+						x509_cert_check(cert_data.ptr, cert_data.len, 3, &path_len) == 1)
+					{
+						is_key_encipher = 1;
+					}
+
+					if (!is_key_encipher)
+					{
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: certificate is not EncCert (no keyEncipherment), skipping");
+						chunk_free(&cert_data);
+						cert->destroy(cert);
+						continue;
+					}
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: certificate has keyEncipherment (EncCert)");
+				}
+
+				/* Extract public key from EncCert using GmSSL */
 				if (x509_cert_get_pubkey &&
 					x509_cert_get_pubkey(cert_data.ptr, cert_data.len,
 										 &x509_key) == 1)
@@ -824,7 +861,7 @@ static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 					if (x509_key.algor == 17 ||  /* OID_sm2 */
 						x509_key.algor == 19)    /* OID_ec_public_key */
 					{
-						DBG1(DBG_IKE, "PQ-GM-IKEv2: found SM2 public key in certificate (algor=%d)",
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: found SM2 public key in EncCert (algor=%d)",
 							 x509_key.algor);
 
 						/* Copy SM2 key */
@@ -834,17 +871,17 @@ static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
 						if (set_global_peer_pubkey)
 						{
 							set_global_peer_pubkey(&sm2_pubkey);
-							DBG1(DBG_IKE, "PQ-GM-IKEv2: stored peer SM2 pubkey globally");
+							DBG1(DBG_IKE, "PQ-GM-IKEv2: stored peer SM2 EncCert pubkey globally for SM2-KEM");
 						}
 					}
 					else
 					{
-						DBG1(DBG_IKE, "PQ-GM-IKEv2: certificate key is not SM2 (algor=%d)", x509_key.algor);
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: EncCert key is not SM2 (algor=%d)", x509_key.algor);
 					}
 				}
 				else
 				{
-					DBG1(DBG_IKE, "PQ-GM-IKEv2: could not extract public key from certificate");
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: could not extract public key from EncCert");
 				}
 				chunk_free(&cert_data);
 			}
diff --git a/src/libstrongswan/plugins/gmalg/gmalg_ke.c b/src/libstrongswan/plugins/gmalg/gmalg_ke.c
