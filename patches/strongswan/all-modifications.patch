Subject: [PATCH 19/41] fix(cert): try both sm2_sign_cert.pem and signCert.pem
 file names

---
 src/libcharon/sa/ikev2/tasks/ike_cert_post.c | 34 ++++++++++++++++----
 1 file changed, 28 insertions(+), 6 deletions(-)

diff --git a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
index fcaacf6056..311b652c06 100644
--- a/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
+++ b/src/libcharon/sa/ikev2/tasks/ike_cert_post.c
@@ -568,19 +568,41 @@ static void build_intermediate_certs(private_ike_cert_post_t *this,
 	sign_cert = auth->get(auth, AUTH_RULE_SUBJECT_CERT);
 	if (!sign_cert)
 	{
+		FILE *fp;
+		const char *sign_cert_path = "/usr/local/etc/swanctl/x509/sm2_sign_cert.pem";
+		const char *enc_cert_path = "/usr/local/etc/swanctl/x509/sm2_enc_cert.pem";
+
 		DBG1(DBG_IKE, "no subject certificate found for IKE_INTERMEDIATE");
 
 		/* PQ-GM-IKEv2: Load SM2 certificates directly from files */
 		/* This bypasses OpenSSL parsing for SM2 certificates */
 		DBG1(DBG_IKE, "PQ-GM-IKEv2: loading SM2 certificates from files");
 
-		/* Send SignCert from file */
-		add_cert_from_file(this, "/usr/local/etc/swanctl/x509/sm2_sign_cert.pem",
-						  "SignCert", message);
+		/* Send SignCert from file - try both naming conventions */
+		fp = fopen(sign_cert_path, "r");
+		if (fp)
+		{
+			fclose(fp);
+			add_cert_from_file(this, sign_cert_path, "SignCert", message);
+		}
+		else
+		{
+			add_cert_from_file(this, "/usr/local/etc/swanctl/x509/signCert.pem",
+							  "SignCert", message);
+		}
 
-		/* Send EncCert from file */
-		add_cert_from_file(this, "/usr/local/etc/swanctl/x509/sm2_enc_cert.pem",
-						  "EncCert", message);
+		/* Send EncCert from file - try both naming conventions */
+		fp = fopen(enc_cert_path, "r");
+		if (fp)
+		{
+			fclose(fp);
+			add_cert_from_file(this, enc_cert_path, "EncCert", message);
+		}
+		else
+		{
+			add_cert_from_file(this, "/usr/local/etc/swanctl/x509/encCert.pem",
+							  "EncCert", message);
+		}
 
 		this->intermediate_certs_sent = TRUE;
 		return;
