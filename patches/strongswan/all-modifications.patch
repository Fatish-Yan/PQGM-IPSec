+/**
+ * Check if certificate has encryption key usage (for SM2-KEM)
+ */
+__attribute__((unused))
+static bool cert_has_encryption_usage(certificate_t *cert)
+{
+	x509_t *x509;
+	x509_flag_t flags;
+
+	if (cert->get_type(cert) != CERT_X509)
+	{
+		return FALSE;
+	}
+
+	x509 = (x509_t*)cert;
+	flags = x509->get_flags(x509);
+
+	/* Check for IKE_INTERMEDIATE EKU or keyEncipherment usage */
+	if ((flags & X509_IKE_INTERMEDIATE) ||
+		(flags & X509_SERVER_AUTH) ||
+		(flags & X509_CLIENT_AUTH))
+	{
+		/* For SM2-KEM, we look for certificates with IKE_INTERMEDIATE EKU
+		 * In practice, we distinguish by checking if it's different from
+		 * the signing certificate */
+		return TRUE;
+	}
+
+	return FALSE;
+}
+
+/**
+ * Add a specific certificate to message
+ */
+static void add_specific_cert(private_ike_cert_post_t *this,
+							  certificate_t *cert, message_t *message)
+{
+	cert_payload_t *payload;
+
+	payload = build_cert_payload(this, cert);
+	if (payload)
+	{
+		DBG1(DBG_IKE, "sending certificate \"%Y\" in IKE_INTERMEDIATE",
+			 cert->get_subject(cert));
+		message->add_payload(message, (payload_t*)payload);
+	}
+}
+
+/**
+ * Find encryption certificate from credential manager
+ * This looks for a certificate with IKE_INTERMEDIATE EKU
+ */
+static certificate_t *find_encryption_cert(private_ike_cert_post_t *this,
+										   identification_t *id)
+{
+	enumerator_t *enumerator;
+	certificate_t *cert, *enc_cert = NULL;
+	x509_t *x509;
+
+	enumerator = lib->credmgr->create_cert_enumerator(lib->credmgr,
+													  CERT_X509, KEY_ANY,
+													  id, FALSE);
+	while (enumerator->enumerate(enumerator, &cert))
+	{
+		if (cert->get_type(cert) == CERT_X509)
+		{
+			x509 = (x509_t*)cert;
+			if (x509->get_flags(x509) & X509_IKE_INTERMEDIATE)
+			{
+				enc_cert = cert->get_ref(cert);
+				break;
+			}
+		}
+	}
+	enumerator->destroy(enumerator);
+
+	/* If no certificate with IKE_INTERMEDIATE EKU found,
+	 * try to find any SM2 certificate with keyEncipherment */
+	if (!enc_cert)
+	{
+		DBG2(DBG_IKE, "no certificate with IKE_INTERMEDIATE EKU found, "
+			 "searching for keyEncipherment certificate");
+		enumerator = lib->credmgr->create_cert_enumerator(lib->credmgr,
+														  CERT_X509, KEY_ANY,
+														  id, FALSE);
+		while (enumerator->enumerate(enumerator, &cert))
+		{
+			if (cert->get_type(cert) == CERT_X509)
+			{
+				x509 = (x509_t*)cert;
+				/* Check for encryption-related key usage */
+				if (x509->get_flags(x509) & X509_SERVER_AUTH)
+				{
+					enc_cert = cert->get_ref(cert);
+					break;
+				}
+			}
+		}
+		enumerator->destroy(enumerator);
+	}
+
+	return enc_cert;
+}
+
+/**
+ * Build certificates for IKE_INTERMEDIATE exchange
+ * Sends dual certificates (SignCert + EncCert) for PQ-GM-IKEv2
+ */
+static void build_intermediate_certs(private_ike_cert_post_t *this,
+									 message_t *message)
+{
+	peer_cfg_t *peer_cfg;
+	auth_cfg_t *auth;
+	certificate_t *sign_cert, *enc_cert;
+	identification_t *id;
+
+	peer_cfg = this->ike_sa->get_peer_cfg(this->ike_sa);
+	if (!peer_cfg)
+	{
+		return;
+	}
+
+	/* Check if peer supports IKE_INTERMEDIATE */
+	if (!this->ike_sa->supports_extension(this->ike_sa, EXT_IKE_INTERMEDIATE))
+	{
+		DBG2(DBG_IKE, "peer does not support IKE_INTERMEDIATE, skipping "
+			 "dual certificate distribution");
+		return;
+	}
+
+	auth = this->ike_sa->get_auth_cfg(this->ike_sa, TRUE);
+	if (!auth)
+	{
+		return;
+	}
+
+	/* Get the signing certificate */
+	sign_cert = auth->get(auth, AUTH_RULE_SUBJECT_CERT);
+	if (!sign_cert)
+	{
+		DBG1(DBG_IKE, "no subject certificate found for IKE_INTERMEDIATE");
+		return;
+	}
+
+	/* Send the signing certificate */
+	DBG1(DBG_IKE, "PQ-GM-IKEv2: sending SignCert in IKE_INTERMEDIATE");
+	add_specific_cert(this, sign_cert, message);
+
+	/* Find and send the encryption certificate for SM2-KEM */
+	id = sign_cert->get_subject(sign_cert);
+	enc_cert = find_encryption_cert(this, id);
+
+	if (enc_cert)
+	{
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: sending EncCert in IKE_INTERMEDIATE");
+		add_specific_cert(this, enc_cert, message);
+		enc_cert->destroy(enc_cert);
+	}
+	else
+	{
+		DBG1(DBG_IKE, "PQ-GM-IKEv2: no EncCert found with IKE_INTERMEDIATE EKU, "
+			 "SignCert will be used for both signing and encryption");
+	}
+
+	this->intermediate_certs_sent = TRUE;
+}
+
+/**
+ * Check if we should send certificates in IKE_INTERMEDIATE
+ */
+static bool should_send_intermediate_certs(private_ike_cert_post_t *this,
+										   message_t *message)
+{
+	/* Only send once */
+	if (this->intermediate_certs_sent)
+	{
+		return FALSE;
+	}
+
+	/* Check if peer supports IKE_INTERMEDIATE */
+	if (!this->ike_sa->supports_extension(this->ike_sa, EXT_IKE_INTERMEDIATE))
+	{
+		return FALSE;
+	}
+
+	/* Check certificate policy */
+	peer_cfg_t *peer_cfg;
+	peer_cfg = this->ike_sa->get_peer_cfg(this->ike_sa);
+	if (!peer_cfg)
+	{
+		return FALSE;
+	}
+
+	switch (peer_cfg->get_cert_policy(peer_cfg))
+	{
+		case CERT_NEVER_SEND:
+			return FALSE;
+		case CERT_SEND_IF_ASKED:
+			if (!this->ike_sa->has_condition(this->ike_sa, COND_CERTREQ_SEEN))
+			{
+				return FALSE;
+			}
+			/* FALL */
+		case CERT_ALWAYS_SEND:
+			return TRUE;
+	}
+
+	return FALSE;
+}
