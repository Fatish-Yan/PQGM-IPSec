+
+METHOD(task_t, process_i, status_t,
+	private_ike_cert_post_t *this, message_t *message)
+{
+	if (!this->ike_sa->has_condition(this->ike_sa, COND_AUTHENTICATED))
+	{	/* stay alive, we might have additional rounds with CERTS */
+		return NEED_MORE;
+	}
+	return SUCCESS;
+}
