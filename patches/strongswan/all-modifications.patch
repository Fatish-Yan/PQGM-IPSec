 	 * once we send the next message, so IntAuth is based on the right keys */
 	return NEED_MORE;
@@ -1637,6 +1701,7 @@ ike_init_t *ike_init_create(ike_sa_t *ike_sa, bool initiator, ike_sa_t *old_sa)
 								"%s.signature_authentication", TRUE, lib->ns),
