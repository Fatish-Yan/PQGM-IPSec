@@ -570,10 +530,11 @@ METHOD(key_exchange_t, get_public_key, bool,
 
 	DBG1(DBG_IKE, "SM2-KEM: get_public_key called");
 
-	/* Priority 1: Use peer_enccert if already set via gmalg_sm2_ke_set_peer_pubkey() */
