-#define SM2_MY_PRIVKEY_FILE "/usr/local/etc/swanctl/private/encKey.pem"
+#define SM2_MY_PRIVKEY_FILE "/usr/local/etc/swanctl/private/sm2_enc_key.pem"
 
 /**
  * Password for encrypted SM2 private key
@@ -341,7 +341,6 @@ static bool initiator_encaps(private_key_exchange_t *this)
 {
 	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
 	size_t ctlen;
-	uint8_t pubkey[65];
 
 	/* Generate our random contribution r_i */
 	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
@@ -351,19 +350,6 @@ static bool initiator_encaps(private_key_exchange_t *this)
 		return FALSE;
 	}
 
-	/* Debug: print my_random (r_i) */
