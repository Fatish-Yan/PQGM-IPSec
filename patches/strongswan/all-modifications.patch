 7 files changed, 587 insertions(+), 3 deletions(-)
 create mode 100644 src/libstrongswan/plugins/mldsa/mldsa_public_key.c
 create mode 100644 src/libstrongswan/plugins/mldsa/mldsa_public_key.h

diff --git a/src/libstrongswan/credentials/credential_manager.c b/src/libstrongswan/credentials/credential_manager.c
index 4f18121214..22175331ca 100644
--- a/src/libstrongswan/credentials/credential_manager.c
+++ b/src/libstrongswan/credentials/credential_manager.c
@@ -1034,8 +1034,106 @@ typedef struct {
 	public_key_t *current;
 	/** credset wrapper around auth config */
 	auth_cfg_wrapper_t *wrapper;
+	/** requested key type */
+	key_type_t type;
 } public_enumerator_t;
 
+/* ML-DSA public key extension OID: 1.3.6.1.4.1.99999.1.2 */
+#define MLDSA_OID_LEN 12
+static const uint8_t MLDSA_OID_DER[] = {0x06, 0x0A, 0x2B, 0x06, 0x01, 0x04, 0x01, 0x86, 0x8D, 0x1F, 0x01, 0x02};
+#define MLDSA65_PUBLIC_KEY_BYTES 1952
+
+/**
+ * Try to extract ML-DSA public key from hybrid certificate extension.
+ */
+static bool try_mldsa_from_hybrid_cert(certificate_t *cert, public_key_t **key)
+{
+	chunk_t encoding, pubkey = chunk_empty;
+	public_key_t *mldsa_key;
+	size_t i;
+
+	/* Get the DER encoding of the certificate */
+	if (!cert->get_encoding(cert, CERT_ASN1_DER, &encoding))
+	{
+		return FALSE;
+	}
+
+	/* Search for the ML-DSA OID in the certificate */
+	for (i = 0; i + MLDSA_OID_LEN < encoding.len; i++)
+	{
+		if (memeq(encoding.ptr + i, MLDSA_OID_DER, MLDSA_OID_LEN))
+		{
+			uint8_t *p = encoding.ptr + i + MLDSA_OID_LEN;
+			size_t remaining = encoding.len - i - MLDSA_OID_LEN;
+
+			DBG1(DBG_LIB, "ML-DSA: found extension OID at offset %zu", i);
+
+			/* Skip ASN.1 framing to find the OCTET STRING */
+			while (remaining > 2)
+			{
+				if (*p == 0x04)
+				{
+					size_t len;
+					p++;
+					remaining--;
+
+					if (*p < 0x80)
+					{
+						len = *p;
+						p++;
+						remaining--;
+					}
+					else if (*p == 0x82 && remaining >= 3)
+					{
+						len = (p[1] << 8) | p[2];
+						p += 3;
+						remaining -= 3;
+					}
+					else
+					{
+						p++;
+						remaining--;
+						continue;
+					}
+
+					if (len >= MLDSA65_PUBLIC_KEY_BYTES && remaining >= MLDSA65_PUBLIC_KEY_BYTES)
+					{
+						pubkey = chunk_clone(chunk_create(p, MLDSA65_PUBLIC_KEY_BYTES));
+						break;
+					}
+				}
+				p++;
+				remaining--;
+			}
+
+			if (pubkey.len > 0)
+			{
+				break;
+			}
+		}
+	}
+
+	chunk_free(&encoding);
+
+	if (pubkey.len == 0)
+	{
+		return FALSE;
+	}
+
+	/* Create ML-DSA public key from extracted data */
+	mldsa_key = lib->creds->create(lib->creds, CRED_PUBLIC_KEY, KEY_MLDSA65,
+								   BUILD_BLOB, pubkey, BUILD_END);
+	chunk_clear(&pubkey);
+
+	if (mldsa_key)
+	{
+		*key = mldsa_key;
+		return TRUE;
+	}
+
+	return FALSE;
+}
+
 METHOD(enumerator_t, public_enumerate, bool,
 	public_enumerator_t *this, va_list args)
 {
@@ -1051,6 +1149,18 @@ METHOD(enumerator_t, public_enumerate, bool,
 		this->current = cert->get_public_key(cert);
 		if (this->current)
 		{
+			/* Check if we need ML-DSA but got a different key type (hybrid cert) */
+			if (this->type == KEY_MLDSA65 && this->current->get_type(this->current) != KEY_MLDSA65)
+			{
+				/* Try to extract ML-DSA public key from certificate extension */
+				public_key_t *mldsa_key = NULL;
+				if (try_mldsa_from_hybrid_cert(cert, &mldsa_key))
+				{
+					DESTROY_IF(this->current);
+					this->current = mldsa_key;
+					DBG1(DBG_LIB, "ML-DSA: extracted public key from hybrid certificate");
+				}
+			}
 			*key = this->current;
 			return TRUE;
 		}
@@ -1088,6 +1198,7 @@ METHOD(credential_manager_t, create_public_enumerator, enumerator_t*,
 		},
 		.inner = create_trusted_enumerator(this, type, id, online),
 		.this = this,
+		.type = type,
 	);
 	if (auth)
 	{
@@ -1347,6 +1458,33 @@ METHOD(credential_manager_t, get_private, private_key_t*,
 		}
 		enumerator->destroy(enumerator);
 	}
+
+	/* Fallback for ML-DSA hybrid certificates:
+	 * If standard lookup failed and we're looking for ML-DSA (or any) key,
+	 * try to find any ML-DSA key directly.
+	 * This supports hybrid certificates where SubjectPublicKeyInfo is ECDSA
+	 * but the actual private key is ML-DSA.
+	 */
+	if (!private && (type == KEY_MLDSA65 || type == KEY_ANY))
+	{
+		enumerator_t *key_enum;
+		private_key_t *key;
+
+		/* Enumerate all ML-DSA keys (NULL keyid = match any) */
+		key_enum = create_private_enumerator(this, KEY_MLDSA65, NULL);
+		if (key_enum)
+		{
+			while (key_enum->enumerate(key_enum, &key))
+			{
+				/* Found an ML-DSA key, use it */
+				private = key->get_ref(key);
+				DBG1(DBG_LIB, "ML-DSA: found ML-DSA private key via fallback lookup");
+				break;
+			}
+			key_enum->destroy(key_enum);
+		}
+	}
+
 	return private;
 }
 
