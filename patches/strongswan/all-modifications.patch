diff --git a/src/libstrongswan/plugins/gmalg/gmalg_ke.c b/src/libstrongswan/plugins/gmalg/gmalg_ke.c
new file mode 100644
index 0000000000..8c9887aeda
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_ke.c
@@ -0,0 +1,323 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_ke.c - SM2-KEM Key Encapsulation Mechanism (Simplified)
+ *
+ * This is a simplified implementation of SM2-KEM that uses temporary
+ * key pairs instead of certificates. For full certificate-based
+ * authentication, the r0 phase (IKE_INTERMEDIATE #0) dual certificate
+ * distribution is required.
+ */
+
+#include <string.h>
+#include <gmssl/sm2.h>
+#include <gmssl/sm2_z256.h>
+#include <gmssl/rand.h>
+
+#include <library.h>
+#include <crypto/key_exchange.h>
+
+#include "gmalg_plugin.h"
+
+
+typedef struct private_key_exchange_t private_key_exchange_t;
+
+/**
+ * Private data of SM2-KEM key exchange
+ */
+struct private_key_exchange_t {
+
+	/**
+	 * Public interface
+	 */
+	key_exchange_t public;
+
+	/**
+	 * Key exchange method (KE_SM2 = 1051)
+	 */
+	key_exchange_method_t method;
+
+	/**
+	 * SM2 key pair (initiator only)
+	 */
+	SM2_KEY sm2_key;
+
+	/**
+	 * Public key export buffer (65 bytes: 0x04 + X + Y)
+	 */
+	chunk_t public_key;
+
+	/**
+	 * Ciphertext received from peer (responder only)
+	 */
+	chunk_t ciphertext;
+
+	/**
+	 * Shared secret (32 bytes)
+	 */
+	chunk_t shared_secret;
+
+	/**
+	 * Flag indicating if we are initiator (have private key)
+	 */
+	bool is_initiator;
+};
+
+/**
+ * SM2-KEM public key size (uncompressed EC point: 0x04 || X || Y)
+ */
+#define SM2_KEM_PUBLIC_KEY_SIZE	65
+
+/**
+ * SM2-KEM shared secret size (32 bytes for KDF output)
+ */
+#define SM2_KEM_SHARED_SECRET_SIZE	32
+
+/**
+ * SM2-KEM encapsulated secret size (max DER-encoded ciphertext)
+ */
+#define SM2_KEM_CIPHERTEXT_SIZE	366
+
+/**
+ * Generate random bytes using GmSSL
+ */
+static bool get_random_bytes(size_t len, uint8_t *out)
+{
+	return rand_bytes(out, len) == 1;
+}
+
+/**
+ * Export SM2 public key in uncompressed format (0x04 || X || Y)
+ */
+static bool export_sm2_public_key(const SM2_KEY *key, uint8_t out[65])
+{
+	/* Use GmSSL function to convert Jacobian point to uncompressed octets */
+	return sm2_z256_point_to_uncompressed_octets(&key->public_key, out) == 1;
+}
+
+/**
+ * Import SM2 public key from uncompressed format (0x04 || X || Y)
+ */
+static bool import_sm2_public_key(const uint8_t in[65], SM2_KEY *key)
+{
+	/* Clear the entire key structure */
+	memset(key, 0, sizeof(SM2_KEY));
+
+	/* Import point from octets (handles format byte and coordinates) */
+	return sm2_z256_point_from_octets(&key->public_key, in, 65) == 1;
+}
+
+/**
+ * Encapsulate a shared secret using SM2 encryption
+ *
+ * Algorithm:
+ * 1. Generate random 32-byte secret
+ * 2. Encrypt secret with peer's public key using SM2
+ * 3. Store secret as shared_secret, return ciphertext
+ */
+static bool encaps_secret(private_key_exchange_t *this,
+						  const SM2_KEY *peer_key)
+{
+	uint8_t secret[32];
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+
+	/* Generate random shared secret */
+	if (!get_random_bytes(32, secret))
+	{
+		return FALSE;
+	}
+
+	/* Encrypt secret using SM2 */
+	ctlen = sizeof(ciphertext);
+	if (sm2_encrypt(peer_key, secret, 32, ciphertext, &ctlen) != 1)
+	{
+		return FALSE;
+	}
+
+	/* Store shared secret */
+	this->shared_secret = chunk_alloc(SM2_KEM_SHARED_SECRET_SIZE);
+	memcpy(this->shared_secret.ptr, secret, 32);
+
+	/* Store ciphertext */
+	this->ciphertext = chunk_alloc(ctlen);
+	memcpy(this->ciphertext.ptr, ciphertext, ctlen);
+
+	return TRUE;
+}
+
+/**
+ * Decapsulate the shared secret from SM2 ciphertext
+ *
+ * Algorithm:
+ * 1. Decrypt ciphertext using our private key
+ * 2. Return the decrypted secret
+ */
+static bool decaps_secret(private_key_exchange_t *this)
+{
+	uint8_t secret[32];
+	size_t secretlen;
+
+	/* Decrypt ciphertext using SM2 */
+	secretlen = sizeof(secret);
+	if (sm2_decrypt(&this->sm2_key, this->ciphertext.ptr, this->ciphertext.len,
+					secret, &secretlen) != 1)
+	{
+		return FALSE;
+	}
+
+	if (secretlen != 32)
+	{
+		return FALSE;
+	}
+
+	/* Store shared secret */
+	this->shared_secret = chunk_alloc(SM2_KEM_SHARED_SECRET_SIZE);
+	memcpy(this->shared_secret.ptr, secret, 32);
+
+	return TRUE;
+}
+
+METHOD(key_exchange_t, get_public_key, bool,
+	private_key_exchange_t *this, chunk_t *value)
+{
+	/* As responder: return ciphertext (already encapsulated) */
+	if (this->ciphertext.ptr)
+	{
+		*value = chunk_clone(this->ciphertext);
+		return TRUE;
+	}
+
+	/* As initiator: generate key pair and return public key */
+	if (this->is_initiator && !this->public_key.ptr)
+	{
+		if (sm2_key_generate(&this->sm2_key) != 1)
+		{
+			return FALSE;
+		}
+
+		/* Allocate buffer for uncompressed EC point (65 bytes) */
+		this->public_key = chunk_alloc(SM2_KEM_PUBLIC_KEY_SIZE);
+
+		/* Export public key in uncompressed format */
+		if (!export_sm2_public_key(&this->sm2_key, this->public_key.ptr))
+		{
+			chunk_clear(&this->public_key);
+			return FALSE;
+		}
+	}
+
+	*value = chunk_clone(this->public_key);
+	return TRUE;
+}
+
+METHOD(key_exchange_t, set_public_key, bool,
+	private_key_exchange_t *this, chunk_t value)
+{
+	SM2_KEY peer_key;
+
+	/* Determine role based on whether we already have a public key:
+	 * - Initiator: generates public key first, then receives ciphertext
+	 * - Responder: receives public key first (no own public key yet)
+	 */
+	if (this->public_key.ptr)
+	{
+		/* We are initiator: receive ciphertext, decapsulate */
+		/* Validate ciphertext size */
+		if (value.len < SM2_MIN_CIPHERTEXT_SIZE ||
+			value.len > SM2_KEM_CIPHERTEXT_SIZE)
+		{
+			DBG1(DBG_LIB, "SM2-KEM: invalid ciphertext size %u", value.len);
+			return FALSE;
+		}
+
+		/* Store ciphertext */
+		this->ciphertext = chunk_clone(value);
+
+		/* Decapsulate shared secret */
+		return decaps_secret(this);
+	}
+	else
+	{
+		/* We are responder: receive public key, encapsulate */
+		/* Validate public key size (uncompressed EC point) */
+		if (value.len != SM2_KEM_PUBLIC_KEY_SIZE)
+		{
+			DBG1(DBG_LIB, "SM2-KEM: invalid public key size %u, expected %u",
+				 value.len, SM2_KEM_PUBLIC_KEY_SIZE);
+			return FALSE;
+		}
+
+		/* Import peer's public key from uncompressed format */
+		if (!import_sm2_public_key(value.ptr, &peer_key))
+		{
+			DBG1(DBG_LIB, "SM2-KEM: failed to import public key");
+			return FALSE;
+		}
+
+		/* Store peer's public key for reference */
+		this->public_key = chunk_clone(value);
+
+		/* Encapsulate shared secret */
+		return encaps_secret(this, &peer_key);
+	}
+
+	return FALSE;
+}
+
+METHOD(key_exchange_t, get_shared_secret, bool,
+	private_key_exchange_t *this, chunk_t *secret)
+{
+	if (!this->shared_secret.ptr)
+	{
+		DBG1(DBG_LIB, "SM2-KEM: shared secret not available");
+		return FALSE;
+	}
+	*secret = chunk_clone(this->shared_secret);
+	return TRUE;
+}
+
+METHOD(key_exchange_t, get_method, key_exchange_method_t,
+	private_key_exchange_t *this)
+{
+	return this->method;
+}
+
+METHOD(key_exchange_t, destroy, void,
+	private_key_exchange_t *this)
+{
+	chunk_clear(&this->public_key);
+	chunk_clear(&this->ciphertext);
+	chunk_clear(&this->shared_secret);
+	memwipe(&this->sm2_key, sizeof(SM2_KEY));
+	free(this);
+}
+
+/*
+ * Described in header file
+ */
+key_exchange_t* gmalg_sm2_ke_create(key_exchange_method_t method)
+{
+	private_key_exchange_t *this;
+
+	if (method != KE_SM2)
+	{
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.get_method = _get_method,
+			.get_public_key = _get_public_key,
+			.set_public_key = _set_public_key,
+			.get_shared_secret = _get_shared_secret,
+			.destroy = _destroy,
+		},
+		.method = method,
+		.is_initiator = TRUE,  /* Default: assume initiator role */
+	);
+
+	memset(&this->sm2_key, 0, sizeof(SM2_KEY));
+
+	return &this->public;
+}
