+		}
 	}
 	return NEED_MORE;
 }
@@ -1185,6 +1224,15 @@ static status_t key_exchange_done(private_ike_init_t *this)
 METHOD(task_t, build_r_multi_ke, status_t,
 	private_ike_init_t *this, message_t *message)
 {
+	/* PQ-GM-IKEv2 5-RTT: First IKE_INTERMEDIATE has no KE, only certificates */
+	if (this->intermediate_round == 0)
