 		return FALSE;
 	}
 
-	/* TODO: Decrypt value (ciphertext) with our private key using SM2 */
-	/* For now, just copy value as peer_random for testing */
-	/* In production, this should use sm2_decrypt_data() */
+	/* Parse into SM2_KEY */
