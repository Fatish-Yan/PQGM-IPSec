 }
 
 METHOD(key_exchange_t, get_shared_secret, bool,
diff --git a/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak b/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak
new file mode 100644
index 0000000000..160444e8a3
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak
@@ -0,0 +1,738 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_ke.c - SM2-KEM Key Encapsulation Mechanism (Bidirectional)
+ *
+ * This implements bidirectional SM2-KEM following the protocol design:
+ * - Initiator generates r_i, encrypts with Responder's EncCert
+ * - Responder generates r_r, encrypts with Initiator's EncCert
+ * - Shared secret = r_i || r_r
+ *
+ * For simplified testing, mock certificates are used until r0 phase
+ * (IKE_INTERMEDIATE #0) dual certificate distribution is implemented.
+ */
+
+#include <string.h>
+#include <gmssl/sm2.h>
+#include <gmssl/sm2_z256.h>
+#include <gmssl/rand.h>
+
+#include <library.h>
+#include <crypto/key_exchange.h>
+
+#include "gmalg_plugin.h"
+
+
+typedef struct private_key_exchange_t private_key_exchange_t;
+
+/**
+ * Private data of SM2-KEM key exchange
+ */
+struct private_key_exchange_t {
+
+	/**
+	 * Public interface
+	 */
+	key_exchange_t public;
+
+	/**
+	 * Key exchange method (KE_SM2 = 1051)
+	 */
+	key_exchange_method_t method;
+
+	/**
+	 * Our SM2 key pair (for decapsulation)
+	 */
+	SM2_KEY my_key;
+
+	/**
+	 * Our public key export buffer (65 bytes: 0x04 + X + Y)
+	 */
+	chunk_t my_pubkey;
+
+	/**
+	 * Peer's EncCert public key (for encapsulation)
+	 * In mock mode: peer's generated public key
+	 */
+	SM2_KEY peer_enccert;
+
+	/**
+	 * Flag: whether peer's EncCert is set
+	 */
+	bool has_peer_enccert;
+
+	/**
+	 * Our random contribution (r_i or r_r)
+	 */
+	chunk_t my_random;
+
+	/**
+	 * Peer's random contribution
+	 */
+	chunk_t peer_random;
+
+	/**
+	 * Final shared secret (r_i || r_r)
+	 */
+	chunk_t shared_secret;
+
+	/**
+	 * Ciphertext to send (encapsulation of our random)
+	 */
+	chunk_t my_ciphertext;
+
+	/**
+	 * Flag: have we called get_public_key first? (determines initiator role)
+	 */
+	bool called_get_pubkey_first;
+
+	/**
+	 * Flag: are we initiator? (determined by first method call)
+	 */
+	bool is_initiator;
+
+	/**
+	 * Mock mode: use generated keys instead of real certificates
+	 */
+	bool mock_mode;
+
+	/**
+	 * Flag: peer_random is from initiator (i.e., we are responder)
+	 * Used to compute SK = r_i || r_r correctly
+	 */
+	bool peer_random_is_initiators;
+
+	/**
+	 * Counter: how many times get_public_key has been called
+	 */
+	int get_pubkey_count;
+
+	/**
+	 * Injected: peer's ID (for certificate lookup)
+	 */
+	identification_t *peer_id;
+
+	/**
+	 * Injected: my ID (for private key lookup)
+	 */
+	identification_t *my_id;
+};
+
+/**
+ * SM2-KEM public key size (uncompressed EC point: 0x04 || X || Y)
+ */
+#define SM2_KEM_PUBLIC_KEY_SIZE		65
+
+/**
+ * SM2-KEM random contribution size (32 bytes)
+ */
+#define SM2_KEM_RANDOM_SIZE		32
+
+/**
+ * SM2-KEM shared secret size (r_i || r_r = 64 bytes)
+ */
+#define SM2_KEM_SHARED_SECRET_SIZE	64
+
+/**
+ * SM2-KEM max ciphertext size (DER-encoded)
+ */
+#define SM2_KEM_CIPHERTEXT_SIZE		366
+
+/**
+ * Generate random bytes using GmSSL
+ */
+static bool get_random_bytes(size_t len, uint8_t *out)
+{
+	return rand_bytes(out, len) == 1;
+}
+
+/**
+ * Export SM2 public key in uncompressed format (0x04 || X || Y)
+ */
+static bool export_sm2_public_key(const SM2_KEY *key, uint8_t out[65])
+{
+	return sm2_z256_point_to_uncompressed_octets(&key->public_key, out) == 1;
+}
+
+/**
+ * Import SM2 public key from uncompressed format (currently unused, kept for future use)
+ */
+__attribute__((unused))
+static bool import_sm2_public_key(const uint8_t in[65], SM2_KEY *key)
+{
+	memset(key, 0, sizeof(SM2_KEY));
+	return sm2_z256_point_from_octets(&key->public_key, in, 65) == 1;
+}
+
+/**
+ * Generate SM2 key pair (currently unused, kept for future use)
+ */
+__attribute__((unused))
+static bool generate_sm2_keypair(SM2_KEY *key)
+{
+	return sm2_key_generate(key) == 1;
+}
+
+/**
+ * SM2 encrypt (encapsulation)
+ */
+static bool sm2_encrypt_data(const SM2_KEY *peer_key,
+							 const uint8_t *plaintext, size_t ptlen,
+							 uint8_t *ciphertext, size_t *ctlen)
+{
+	return sm2_encrypt(peer_key, plaintext, ptlen, ciphertext, ctlen) == 1;
+}
+
+/**
+ * SM2 decrypt (decapsulation)
+ */
+static bool sm2_decrypt_data(const SM2_KEY *my_key,
+							 const uint8_t *ciphertext, size_t ctlen,
+							 uint8_t *plaintext, size_t *ptlen)
+{
+	return sm2_decrypt(my_key, ciphertext, ctlen, plaintext, ptlen) == 1;
+}
+
+/**
+ * Initiator: encapsulate our random (r_i) using peer's EncCert
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool initiator_encaps(private_key_exchange_t *this)
+{
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+	uint8_t pubkey[65];
+
+	/* Generate our random contribution r_i */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Debug: print my_random (r_i) */
+	fprintf(stderr, "DEBUG initiator_encaps: my_random (r_i) = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", this->my_random.ptr[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Debug: print peer_enccert public key */
+	export_sm2_public_key(&this->peer_enccert, pubkey);
+	fprintf(stderr, "DEBUG initiator_encaps: peer_enccert = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", pubkey[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Encrypt r_i with peer's EncCert public key */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Store ciphertext to send */
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	return TRUE;
+}
+
+/**
+ * Initiator: decapsulate peer's random (r_r) from received ciphertext
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool initiator_decaps(private_key_exchange_t *this, chunk_t ciphertext)
+{
+	uint8_t plaintext[SM2_KEM_RANDOM_SIZE];
+	size_t ptlen;
+
+	/* Decrypt ciphertext using our private key */
+	ptlen = sizeof(plaintext);
+	if (!sm2_decrypt_data(&this->my_key,
+						  ciphertext.ptr, ciphertext.len,
+						  plaintext, &ptlen))
+	{
+		return FALSE;
+	}
+
+	if (ptlen != SM2_KEM_RANDOM_SIZE)
+	{
+		return FALSE;
+	}
+
+	/* Store peer's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext, ptlen);
+
+	return TRUE;
+}
+
+/**
+ * Responder: decapsulate initiator's random (r_i) from received ciphertext
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool responder_decaps(private_key_exchange_t *this, chunk_t ciphertext)
+{
+	uint8_t plaintext[SM2_KEM_RANDOM_SIZE];
+	size_t ptlen;
+	uint8_t my_pubkey[65];
+
+	fprintf(stderr, "DEBUG responder_decaps: ctlen=%zu\n", ciphertext.len);
+	fflush(stderr);
+
+	/* Debug: print my public key (should match what Initiator used to encrypt) */
+	export_sm2_public_key(&this->my_key, my_pubkey);
+	fprintf(stderr, "DEBUG responder_decaps: my_pubkey = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", my_pubkey[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Decrypt ciphertext using our private key */
+	ptlen = sizeof(plaintext);
+	if (!sm2_decrypt_data(&this->my_key,
+						  ciphertext.ptr, ciphertext.len,
+						  plaintext, &ptlen))
+	{
+		fprintf(stderr, "DEBUG: sm2_decrypt_data failed\n");
+		fflush(stderr);
+		return FALSE;
+	}
+
+	if (ptlen != SM2_KEM_RANDOM_SIZE)
+	{
+		fprintf(stderr, "DEBUG: ptlen=%zu != %d\n", ptlen, SM2_KEM_RANDOM_SIZE);
+		fflush(stderr);
+		return FALSE;
+	}
+
+	/* Store initiator's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext, ptlen);
+
+	/* Debug: print decrypted value */
+	fprintf(stderr, "DEBUG responder_decaps: peer_random (r_i) = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", this->peer_random.ptr[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	return TRUE;
+}
+
+/**
+ * Responder: encapsulate our random (r_r) using peer's EncCert
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool responder_encaps(private_key_exchange_t *this)
+{
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+
+	/* Generate our random contribution r_r */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Encrypt r_r with peer's EncCert public key */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Store ciphertext to send */
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	return TRUE;
+}
+
+/**
+ * Compute final shared secret: SK = r_i || r_r
+ * Both parties must compute in the same order: initiator's random first
+ */
+static bool compute_shared_secret(private_key_exchange_t *this)
+{
+	if (!this->my_random.ptr || !this->peer_random.ptr)
+	{
+		fprintf(stderr, "DEBUG: compute_shared_secret missing randoms: my=%p peer=%p\n",
+				this->my_random.ptr, this->peer_random.ptr);
+		fflush(stderr);
+		return FALSE;
+	}
+
+	this->shared_secret = chunk_alloc(SM2_KEM_SHARED_SECRET_SIZE);
+
+	/*
+	 * SK = r_i || r_r
+	 *
+	 * - Initiator: my_random = r_i, peer_random = r_r
+	 * - Responder: my_random = r_r, peer_random = r_i
+	 *
+	 * So:
+	 * - Initiator: SK = my_random || peer_random
+	 * - Responder: SK = peer_random || my_random
+	 */
+	if (this->is_initiator)
+	{
+		fprintf(stderr, "DEBUG: Initiator computing SK = my_random || peer_random\n");
+		fflush(stderr);
+		memcpy(this->shared_secret.ptr,
+			   this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+		memcpy(this->shared_secret.ptr + SM2_KEM_RANDOM_SIZE,
+			   this->peer_random.ptr, SM2_KEM_RANDOM_SIZE);
+	}
+	else
+	{
+		fprintf(stderr, "DEBUG: Responder computing SK = peer_random || my_random\n");
+		fflush(stderr);
+		memcpy(this->shared_secret.ptr,
+			   this->peer_random.ptr, SM2_KEM_RANDOM_SIZE);
+		memcpy(this->shared_secret.ptr + SM2_KEM_RANDOM_SIZE,
+			   this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+	}
+
+	return TRUE;
+}
+
+METHOD(key_exchange_t, get_method, key_exchange_method_t,
+	private_key_exchange_t *this)
+{
+	return this->method;
+}
+
+METHOD(key_exchange_t, get_public_key, bool,
+	private_key_exchange_t *this, chunk_t *value)
+{
+	certificate_t *peer_enc_cert = NULL;
+	public_key_t *peer_pubkey = NULL;
+	enumerator_t *enumerator;
+	chunk_t ciphertext = chunk_empty;
+	rng_t *rng;
+	uint8_t *ciphertext_buf;
+	size_t ctlen;
+
+	DBG1(DBG_IKE, "SM2-KEM: get_public_key called");
+
+	if (!this->peer_id)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: peer_id not set, cannot find EncCert");
+		return FALSE;
+	}
+
+	/* Find peer's EncCert public key using lib->credmgr */
+	enumerator = lib->credmgr->create_cert_enumerator(lib->credmgr,
+		CERT_X509, KEY_ANY, this->peer_id, TRUE);
+
+	if (enumerator && enumerator->enumerate(enumerator, &peer_enc_cert))
+	{
+		peer_enc_cert->get_ref(peer_enc_cert);
+	}
+	if (enumerator)
+	{
+		enumerator->destroy(enumerator);
+	}
+
+	if (!peer_enc_cert)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: EncCert not found for %Y", this->peer_id);
+		return FALSE;
+	}
+
+	/* Extract public key */
+	peer_pubkey = peer_enc_cert->get_public_key(peer_enc_cert);
+	peer_enc_cert->destroy(peer_enc_cert);
+
+	if (!peer_pubkey)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to extract public key from EncCert");
+		return FALSE;
+	}
+
+	/* Generate random using strongSwan RNG */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	rng = lib->crypto->create_rng(lib->crypto, RNG_STRONG);
+	if (!rng || !rng->get_bytes(rng, this->my_random.len, this->my_random.ptr))
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to generate random bytes");
+		DESTROY_IF(rng);
+		chunk_clear(&this->my_random);
+		peer_pubkey->destroy(peer_pubkey);
+		return FALSE;
+	}
+	DESTROY_IF(rng);
+
+	DBG1(DBG_IKE, "SM2-KEM: generated my_random");
+
+	/* TODO: Encrypt my_random with peer's public key using SM2 */
+	/* For now, return my_random as the "ciphertext" for testing */
+	/* In production, this should use sm2_encrypt_data() */
+
+	/* Allocate ciphertext buffer */
+	ciphertext_buf = malloc(SM2_KEM_CIPHERTEXT_SIZE);
+	ctlen = SM2_KEM_CIPHERTEXT_SIZE;
+
+	/* For testing: just copy my_random as ciphertext */
+	memcpy(ciphertext_buf, this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+	ctlen = SM2_KEM_RANDOM_SIZE;
+
+	ciphertext = chunk_create(ciphertext_buf, ctlen);
+	*value = chunk_clone(ciphertext);
+
+	free(ciphertext_buf);
+	peer_pubkey->destroy(peer_pubkey);
+
+	DBG1(DBG_IKE, "SM2-KEM: returning ciphertext of %zu bytes", value->len);
+	return TRUE;
+}
+
+METHOD(key_exchange_t, set_public_key, bool,
+	private_key_exchange_t *this, chunk_t value)
+{
+	private_key_t *my_privkey = NULL;
+	uint8_t *plaintext_buf;
+	size_t ptlen;
+
+	DBG1(DBG_IKE, "SM2-KEM: set_public_key called with %zu bytes", value.len);
+
+	if (!this->my_id)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: my_id not set, cannot find private key");
+		return FALSE;
+	}
+
+	/* Find our SM2 private key using lib->credmgr */
+	my_privkey = lib->credmgr->get_private(lib->credmgr,
+		KEY_ANY, this->my_id, NULL);
+
+	if (!my_privkey)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: SM2 private key not found for %Y", this->my_id);
+		return FALSE;
+	}
+
+	/* TODO: Decrypt value (ciphertext) with our private key using SM2 */
+	/* For now, just copy value as peer_random for testing */
+	/* In production, this should use sm2_decrypt_data() */
+
+	/* Allocate plaintext buffer */
+	plaintext_buf = malloc(SM2_KEM_RANDOM_SIZE);
+	ptlen = SM2_KEM_RANDOM_SIZE;
+
+	/* For testing: just copy value as plaintext */
+	memcpy(plaintext_buf, value.ptr, SM2_KEM_RANDOM_SIZE);
+	ptlen = SM2_KEM_RANDOM_SIZE;
+
+	/* Store peer's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext_buf, ptlen);
+
+	free(plaintext_buf);
+	my_privkey->destroy(my_privkey);
+
+	DBG1(DBG_IKE, "SM2-KEM: decrypted peer_random");
+
+	/* Compute final shared secret */
+	return compute_shared_secret(this);
+}
+
+METHOD(key_exchange_t, get_shared_secret, bool,
+	private_key_exchange_t *this, chunk_t *secret)
+{
+	if (!this->shared_secret.ptr)
+	{
+		DBG1(DBG_LIB, "SM2-KEM: shared secret not available");
+		return FALSE;
+	}
+	*secret = chunk_clone(this->shared_secret);
+	return TRUE;
+}
+
+/**
+ * Set peer's ID for certificate lookup
+ */
+void gmalg_sm2_ke_set_peer_id(key_exchange_t *ke, identification_t *peer_id)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	DESTROY_IF(this->peer_id);
+	this->peer_id = peer_id->clone(peer_id);
+}
+
+/**
+ * Set my ID for private key lookup
+ */
+void gmalg_sm2_ke_set_my_id(key_exchange_t *ke, identification_t *my_id)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	DESTROY_IF(this->my_id);
+	this->my_id = my_id->clone(my_id);
+}
+
+/**
+ * Set role (initiator or responder)
+ */
+void gmalg_sm2_ke_set_role(key_exchange_t *ke, bool is_initiator)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	this->is_initiator = is_initiator;
+}
+
+METHOD(key_exchange_t, destroy, void,
+	private_key_exchange_t *this)
+{
+	chunk_clear(&this->my_pubkey);
+	chunk_clear(&this->my_random);
+	chunk_clear(&this->peer_random);
+	chunk_clear(&this->my_ciphertext);
+	chunk_clear(&this->shared_secret);
+	memwipe(&this->my_key, sizeof(SM2_KEY));
+	memwipe(&this->peer_enccert, sizeof(SM2_KEY));
+
+	/* Release injected IDs */
+	DESTROY_IF(this->peer_id);
+	DESTROY_IF(this->my_id);
+
+	free(this);
+}
+
+/*
+ * Create SM2-KEM instance with pre-distributed keys
+ *
+ * This simulates the R0 certificate exchange phase where both parties
+ * already have their own key pair and the peer's public key.
+ * Since we have peer's EncCert, we can immediately encapsulate.
+ */
+key_exchange_t* gmalg_sm2_ke_create_with_keys(key_exchange_method_t method,
+											  bool is_initiator,
+											  const SM2_KEY *my_key,
+											  const SM2_KEY *peer_pubkey)
+{
+	private_key_exchange_t *this;
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+
+	if (method != KE_SM2 || !my_key || !peer_pubkey)
+	{
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.get_method = _get_method,
+			.get_public_key = _get_public_key,
+			.set_public_key = _set_public_key,
+			.get_shared_secret = _get_shared_secret,
+			.destroy = _destroy,
+		},
+		.method = method,
+		.is_initiator = is_initiator,
+		.mock_mode = FALSE,  /* Using real pre-distributed keys */
+		.peer_random_is_initiators = FALSE,
+		.get_pubkey_count = 0,
+	);
+
+	/* Copy our key pair */
+	memcpy(&this->my_key, my_key, sizeof(SM2_KEY));
+
+	/* Copy peer's public key */
+	memcpy(&this->peer_enccert, peer_pubkey, sizeof(SM2_KEY));
+	this->has_peer_enccert = TRUE;
+
+	/* Export our public key for get_public_key */
+	this->my_pubkey = chunk_alloc(SM2_KEM_PUBLIC_KEY_SIZE);
+	if (!export_sm2_public_key(&this->my_key, this->my_pubkey.ptr))
+	{
+		chunk_clear(&this->my_pubkey);
+		free(this);
+		return NULL;
+	}
+
+	/* Since we have peer's EncCert, encapsulate immediately */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_pubkey);
+		chunk_clear(&this->my_random);
+		free(this);
+		return NULL;
+	}
+
+	/* Encrypt our random with peer's EncCert */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_pubkey);
+		chunk_clear(&this->my_random);
+		free(this);
+		return NULL;
+	}
+
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	fprintf(stderr, "DEBUG: Created SM2-KEM with pre-distributed keys, is_initiator=%d, encapsulated\n",
+			is_initiator);
+	fflush(stderr);
+
+	return &this->public;
+}
+
+/*
+ * Create SM2-KEM instance with specified role
+ */
+key_exchange_t* gmalg_sm2_ke_create_with_role(key_exchange_method_t method,
+											  bool is_initiator)
+{
+	private_key_exchange_t *this;
+
+	if (method != KE_SM2)
+	{
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.get_method = _get_method,
+			.get_public_key = _get_public_key,
+			.set_public_key = _set_public_key,
+			.get_shared_secret = _get_shared_secret,
+			.destroy = _destroy,
+		},
+		.method = method,
+		.is_initiator = is_initiator,
+		.mock_mode = TRUE,  /* Use mock certificates for now */
+		.peer_random_is_initiators = FALSE,
+		.get_pubkey_count = 0,
+	);
+
+	memset(&this->my_key, 0, sizeof(SM2_KEY));
+	memset(&this->peer_enccert, 0, sizeof(SM2_KEY));
+
+	fprintf(stderr, "DEBUG: Created SM2-KEM instance, is_initiator=%d\n", is_initiator);
+	fflush(stderr);
+
+	return &this->public;
+}
+
+/*
+ * Create SM2-KEM instance (defaults to initiator role)
+ */
+key_exchange_t* gmalg_sm2_ke_create(key_exchange_method_t method)
+{
+	return gmalg_sm2_ke_create_with_role(method, TRUE);
+}
diff --git a/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak3 b/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak3
new file mode 100644
index 0000000000..3516308496
--- /dev/null
+++ b/src/libstrongswan/plugins/gmalg/gmalg_ke.c.bak3
@@ -0,0 +1,739 @@
+/*
+ * Copyright (C) 2025 PQGM-IKEv2 Project
+ *
+ * gmalg_ke.c - SM2-KEM Key Encapsulation Mechanism (Bidirectional)
+ *
+ * This implements bidirectional SM2-KEM following the protocol design:
+ * - Initiator generates r_i, encrypts with Responder's EncCert
+ * - Responder generates r_r, encrypts with Initiator's EncCert
+ * - Shared secret = r_i || r_r
+ *
+ * For simplified testing, mock certificates are used until r0 phase
+ * (IKE_INTERMEDIATE #0) dual certificate distribution is implemented.
+ */
+
+#include <string.h>
+#include <gmssl/sm2.h>
+#include <gmssl/sm2_z256.h>
+#include <gmssl/rand.h>
+
+#include <library.h>
+#include <credentials/certificates/x509.h>
+#include <crypto/key_exchange.h>
+
+#include "gmalg_plugin.h"
+
+
+typedef struct private_key_exchange_t private_key_exchange_t;
+
+/**
+ * Private data of SM2-KEM key exchange
+ */
+struct private_key_exchange_t {
+
+	/**
+	 * Public interface
+	 */
+	key_exchange_t public;
+
+	/**
+	 * Key exchange method (KE_SM2 = 1051)
+	 */
+	key_exchange_method_t method;
+
+	/**
+	 * Our SM2 key pair (for decapsulation)
+	 */
+	SM2_KEY my_key;
+
+	/**
+	 * Our public key export buffer (65 bytes: 0x04 + X + Y)
+	 */
+	chunk_t my_pubkey;
+
+	/**
+	 * Peer's EncCert public key (for encapsulation)
+	 * In mock mode: peer's generated public key
+	 */
+	SM2_KEY peer_enccert;
+
+	/**
+	 * Flag: whether peer's EncCert is set
+	 */
+	bool has_peer_enccert;
+
+	/**
+	 * Our random contribution (r_i or r_r)
+	 */
+	chunk_t my_random;
+
+	/**
+	 * Peer's random contribution
+	 */
+	chunk_t peer_random;
+
+	/**
+	 * Final shared secret (r_i || r_r)
+	 */
+	chunk_t shared_secret;
+
+	/**
+	 * Ciphertext to send (encapsulation of our random)
+	 */
+	chunk_t my_ciphertext;
+
+	/**
+	 * Flag: have we called get_public_key first? (determines initiator role)
+	 */
+	bool called_get_pubkey_first;
+
+	/**
+	 * Flag: are we initiator? (determined by first method call)
+	 */
+	bool is_initiator;
+
+	/**
+	 * Mock mode: use generated keys instead of real certificates
+	 */
+	bool mock_mode;
+
+	/**
+	 * Flag: peer_random is from initiator (i.e., we are responder)
+	 * Used to compute SK = r_i || r_r correctly
+	 */
+	bool peer_random_is_initiators;
+
+	/**
+	 * Counter: how many times get_public_key has been called
+	 */
+	int get_pubkey_count;
+
+	/**
+	 * Injected: peer's ID (for certificate lookup)
+	 */
+	identification_t *peer_id;
+
+	/**
+	 * Injected: my ID (for private key lookup)
+	 */
+	identification_t *my_id;
+};
+
+/**
+ * SM2-KEM public key size (uncompressed EC point: 0x04 || X || Y)
+ */
+#define SM2_KEM_PUBLIC_KEY_SIZE		65
+
+/**
+ * SM2-KEM random contribution size (32 bytes)
+ */
+#define SM2_KEM_RANDOM_SIZE		32
+
+/**
+ * SM2-KEM shared secret size (r_i || r_r = 64 bytes)
+ */
+#define SM2_KEM_SHARED_SECRET_SIZE	64
+
+/**
+ * SM2-KEM max ciphertext size (DER-encoded)
+ */
+#define SM2_KEM_CIPHERTEXT_SIZE		366
+
+/**
+ * Generate random bytes using GmSSL
+ */
+static bool get_random_bytes(size_t len, uint8_t *out)
+{
+	return rand_bytes(out, len) == 1;
+}
+
+/**
+ * Export SM2 public key in uncompressed format (0x04 || X || Y)
+ */
+static bool export_sm2_public_key(const SM2_KEY *key, uint8_t out[65])
+{
+	return sm2_z256_point_to_uncompressed_octets(&key->public_key, out) == 1;
+}
+
+/**
+ * Import SM2 public key from uncompressed format (currently unused, kept for future use)
+ */
+__attribute__((unused))
+static bool import_sm2_public_key(const uint8_t in[65], SM2_KEY *key)
+{
+	memset(key, 0, sizeof(SM2_KEY));
+	return sm2_z256_point_from_octets(&key->public_key, in, 65) == 1;
+}
+
+/**
+ * Generate SM2 key pair (currently unused, kept for future use)
+ */
+__attribute__((unused))
+static bool generate_sm2_keypair(SM2_KEY *key)
+{
+	return sm2_key_generate(key) == 1;
+}
+
+/**
+ * SM2 encrypt (encapsulation)
+ */
+static bool sm2_encrypt_data(const SM2_KEY *peer_key,
+							 const uint8_t *plaintext, size_t ptlen,
+							 uint8_t *ciphertext, size_t *ctlen)
+{
+	return sm2_encrypt(peer_key, plaintext, ptlen, ciphertext, ctlen) == 1;
+}
+
+/**
+ * SM2 decrypt (decapsulation)
+ */
+static bool sm2_decrypt_data(const SM2_KEY *my_key,
+							 const uint8_t *ciphertext, size_t ctlen,
+							 uint8_t *plaintext, size_t *ptlen)
+{
+	return sm2_decrypt(my_key, ciphertext, ctlen, plaintext, ptlen) == 1;
+}
+
+/**
+ * Initiator: encapsulate our random (r_i) using peer's EncCert
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool initiator_encaps(private_key_exchange_t *this)
+{
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+	uint8_t pubkey[65];
+
+	/* Generate our random contribution r_i */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Debug: print my_random (r_i) */
+	fprintf(stderr, "DEBUG initiator_encaps: my_random (r_i) = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", this->my_random.ptr[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Debug: print peer_enccert public key */
+	export_sm2_public_key(&this->peer_enccert, pubkey);
+	fprintf(stderr, "DEBUG initiator_encaps: peer_enccert = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", pubkey[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Encrypt r_i with peer's EncCert public key */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Store ciphertext to send */
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	return TRUE;
+}
+
+/**
+ * Initiator: decapsulate peer's random (r_r) from received ciphertext
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool initiator_decaps(private_key_exchange_t *this, chunk_t ciphertext)
+{
+	uint8_t plaintext[SM2_KEM_RANDOM_SIZE];
+	size_t ptlen;
+
+	/* Decrypt ciphertext using our private key */
+	ptlen = sizeof(plaintext);
+	if (!sm2_decrypt_data(&this->my_key,
+						  ciphertext.ptr, ciphertext.len,
+						  plaintext, &ptlen))
+	{
+		return FALSE;
+	}
+
+	if (ptlen != SM2_KEM_RANDOM_SIZE)
+	{
+		return FALSE;
+	}
+
+	/* Store peer's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext, ptlen);
+
+	return TRUE;
+}
+
+/**
+ * Responder: decapsulate initiator's random (r_i) from received ciphertext
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool responder_decaps(private_key_exchange_t *this, chunk_t ciphertext)
+{
+	uint8_t plaintext[SM2_KEM_RANDOM_SIZE];
+	size_t ptlen;
+	uint8_t my_pubkey[65];
+
+	fprintf(stderr, "DEBUG responder_decaps: ctlen=%zu\n", ciphertext.len);
+	fflush(stderr);
+
+	/* Debug: print my public key (should match what Initiator used to encrypt) */
+	export_sm2_public_key(&this->my_key, my_pubkey);
+	fprintf(stderr, "DEBUG responder_decaps: my_pubkey = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", my_pubkey[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	/* Decrypt ciphertext using our private key */
+	ptlen = sizeof(plaintext);
+	if (!sm2_decrypt_data(&this->my_key,
+						  ciphertext.ptr, ciphertext.len,
+						  plaintext, &ptlen))
+	{
+		fprintf(stderr, "DEBUG: sm2_decrypt_data failed\n");
+		fflush(stderr);
+		return FALSE;
+	}
+
+	if (ptlen != SM2_KEM_RANDOM_SIZE)
+	{
+		fprintf(stderr, "DEBUG: ptlen=%zu != %d\n", ptlen, SM2_KEM_RANDOM_SIZE);
+		fflush(stderr);
+		return FALSE;
+	}
+
+	/* Store initiator's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext, ptlen);
+
+	/* Debug: print decrypted value */
+	fprintf(stderr, "DEBUG responder_decaps: peer_random (r_i) = ");
+	for (int i = 0; i < 8; i++) fprintf(stderr, "%02x", this->peer_random.ptr[i]);
+	fprintf(stderr, "...\n");
+	fflush(stderr);
+
+	return TRUE;
+}
+
+/**
+ * Responder: encapsulate our random (r_r) using peer's EncCert
+ * (Currently unused - logic inlined in set_public_key)
+ */
+__attribute__((unused))
+static bool responder_encaps(private_key_exchange_t *this)
+{
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+
+	/* Generate our random contribution r_r */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Encrypt r_r with peer's EncCert public key */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_random);
+		return FALSE;
+	}
+
+	/* Store ciphertext to send */
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	return TRUE;
+}
+
+/**
+ * Compute final shared secret: SK = r_i || r_r
+ * Both parties must compute in the same order: initiator's random first
+ */
+static bool compute_shared_secret(private_key_exchange_t *this)
+{
+	if (!this->my_random.ptr || !this->peer_random.ptr)
+	{
+		fprintf(stderr, "DEBUG: compute_shared_secret missing randoms: my=%p peer=%p\n",
+				this->my_random.ptr, this->peer_random.ptr);
+		fflush(stderr);
+		return FALSE;
+	}
+
+	this->shared_secret = chunk_alloc(SM2_KEM_SHARED_SECRET_SIZE);
+
+	/*
+	 * SK = r_i || r_r
+	 *
+	 * - Initiator: my_random = r_i, peer_random = r_r
+	 * - Responder: my_random = r_r, peer_random = r_i
+	 *
+	 * So:
+	 * - Initiator: SK = my_random || peer_random
+	 * - Responder: SK = peer_random || my_random
+	 */
+	if (this->is_initiator)
+	{
+		fprintf(stderr, "DEBUG: Initiator computing SK = my_random || peer_random\n");
+		fflush(stderr);
+		memcpy(this->shared_secret.ptr,
+			   this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+		memcpy(this->shared_secret.ptr + SM2_KEM_RANDOM_SIZE,
+			   this->peer_random.ptr, SM2_KEM_RANDOM_SIZE);
+	}
+	else
+	{
+		fprintf(stderr, "DEBUG: Responder computing SK = peer_random || my_random\n");
+		fflush(stderr);
+		memcpy(this->shared_secret.ptr,
+			   this->peer_random.ptr, SM2_KEM_RANDOM_SIZE);
+		memcpy(this->shared_secret.ptr + SM2_KEM_RANDOM_SIZE,
+			   this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+	}
+
+	return TRUE;
+}
+
+METHOD(key_exchange_t, get_method, key_exchange_method_t,
+	private_key_exchange_t *this)
+{
+	return this->method;
+}
+
+METHOD(key_exchange_t, get_public_key, bool,
+	private_key_exchange_t *this, chunk_t *value)
+{
+	certificate_t *peer_enc_cert = NULL;
+	public_key_t *peer_pubkey = NULL;
+	enumerator_t *enumerator;
+	chunk_t ciphertext = chunk_empty;
+	rng_t *rng;
+	uint8_t *ciphertext_buf;
+	size_t ctlen;
+
+	DBG1(DBG_IKE, "SM2-KEM: get_public_key called");
+
+	if (0) /* peer_id check disabled */
+	{
+		DBG1(DBG_IKE, "SM2-KEM: peer_id not set, cannot find EncCert");
+		return FALSE;
+	}
+
+	/* Find peer's EncCert public key using lib->credmgr */
+	enumerator = lib->credmgr->create_cert_enumerator(lib->credmgr,
+		CERT_X509, KEY_ANY, NULL, TRUE);
+
+	if (enumerator && enumerator->enumerate(enumerator, &peer_enc_cert))
+	{
+		peer_enc_cert->get_ref(peer_enc_cert);
+	}
+	if (enumerator)
+	{
+		enumerator->destroy(enumerator);
+	}
+
+	if (!peer_enc_cert)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: EncCert not found for %Y", this->peer_id);
+		return FALSE;
+	}
+
+	/* Extract public key */
+	peer_pubkey = peer_enc_cert->get_public_key(peer_enc_cert);
+	peer_enc_cert->destroy(peer_enc_cert);
+
+	if (!peer_pubkey)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to extract public key from EncCert");
+		return FALSE;
+	}
+
+	/* Generate random using strongSwan RNG */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	rng = lib->crypto->create_rng(lib->crypto, RNG_STRONG);
+	if (!rng || !rng->get_bytes(rng, this->my_random.len, this->my_random.ptr))
+	{
+		DBG1(DBG_IKE, "SM2-KEM: failed to generate random bytes");
+		DESTROY_IF(rng);
+		chunk_clear(&this->my_random);
+		peer_pubkey->destroy(peer_pubkey);
+		return FALSE;
+	}
+	DESTROY_IF(rng);
+
+	DBG1(DBG_IKE, "SM2-KEM: generated my_random");
+
+	/* TODO: Encrypt my_random with peer's public key using SM2 */
+	/* For now, return my_random as the "ciphertext" for testing */
+	/* In production, this should use sm2_encrypt_data() */
+
+	/* Allocate ciphertext buffer */
+	ciphertext_buf = malloc(SM2_KEM_CIPHERTEXT_SIZE);
+	ctlen = SM2_KEM_CIPHERTEXT_SIZE;
+
+	/* For testing: just copy my_random as ciphertext */
+	memcpy(ciphertext_buf, this->my_random.ptr, SM2_KEM_RANDOM_SIZE);
+	ctlen = SM2_KEM_RANDOM_SIZE;
+
+	ciphertext = chunk_create(ciphertext_buf, ctlen);
+	*value = chunk_clone(ciphertext);
+
+	free(ciphertext_buf);
+	peer_pubkey->destroy(peer_pubkey);
+
+	DBG1(DBG_IKE, "SM2-KEM: returning ciphertext of %zu bytes", value->len);
+	return TRUE;
+}
+
+METHOD(key_exchange_t, set_public_key, bool,
+	private_key_exchange_t *this, chunk_t value)
+{
+	private_key_t *my_privkey = NULL;
+	uint8_t *plaintext_buf;
+	size_t ptlen;
+
+	DBG1(DBG_IKE, "SM2-KEM: set_public_key called with %zu bytes", value.len);
+
+	if (0) /* my_id check disabled */
+	{
+		DBG1(DBG_IKE, "SM2-KEM: my_id not set, cannot find private key");
+		return FALSE;
+	}
+
+	/* Find our SM2 private key using lib->credmgr */
+	my_privkey = lib->credmgr->get_private(lib->credmgr,
+		KEY_ANY, NULL, NULL);
+
+	if (!my_privkey)
+	{
+		DBG1(DBG_IKE, "SM2-KEM: SM2 private key not found for %Y", this->my_id);
+		return FALSE;
+	}
+
+	/* TODO: Decrypt value (ciphertext) with our private key using SM2 */
+	/* For now, just copy value as peer_random for testing */
+	/* In production, this should use sm2_decrypt_data() */
+
+	/* Allocate plaintext buffer */
+	plaintext_buf = malloc(SM2_KEM_RANDOM_SIZE);
+	ptlen = SM2_KEM_RANDOM_SIZE;
+
+	/* For testing: just copy value as plaintext */
+	memcpy(plaintext_buf, value.ptr, SM2_KEM_RANDOM_SIZE);
+	ptlen = SM2_KEM_RANDOM_SIZE;
+
+	/* Store peer's random contribution */
+	this->peer_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	memcpy(this->peer_random.ptr, plaintext_buf, ptlen);
+
+	free(plaintext_buf);
+	my_privkey->destroy(my_privkey);
+
+	DBG1(DBG_IKE, "SM2-KEM: decrypted peer_random");
+
+	/* Compute final shared secret */
+	return compute_shared_secret(this);
+}
+
+METHOD(key_exchange_t, get_shared_secret, bool,
+	private_key_exchange_t *this, chunk_t *secret)
+{
+	if (!this->shared_secret.ptr)
+	{
+		DBG1(DBG_LIB, "SM2-KEM: shared secret not available");
+		return FALSE;
+	}
+	*secret = chunk_clone(this->shared_secret);
+	return TRUE;
+}
+
+/**
+ * Set peer's ID for certificate lookup
+ */
+void gmalg_sm2_ke_set_peer_id(key_exchange_t *ke, identification_t *peer_id)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	DESTROY_IF(this->peer_id);
+	this->peer_id = peer_id->clone(peer_id);
+}
+
+/**
+ * Set my ID for private key lookup
+ */
+void gmalg_sm2_ke_set_my_id(key_exchange_t *ke, identification_t *my_id)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	DESTROY_IF(this->my_id);
+	this->my_id = my_id->clone(my_id);
+}
+
+/**
+ * Set role (initiator or responder)
+ */
+void gmalg_sm2_ke_set_role(key_exchange_t *ke, bool is_initiator)
+{
+	private_key_exchange_t *this = (private_key_exchange_t*)ke;
+	this->is_initiator = is_initiator;
+}
+
+METHOD(key_exchange_t, destroy, void,
+	private_key_exchange_t *this)
+{
+	chunk_clear(&this->my_pubkey);
+	chunk_clear(&this->my_random);
+	chunk_clear(&this->peer_random);
+	chunk_clear(&this->my_ciphertext);
+	chunk_clear(&this->shared_secret);
+	memwipe(&this->my_key, sizeof(SM2_KEY));
+	memwipe(&this->peer_enccert, sizeof(SM2_KEY));
+
+	/* Release injected IDs */
+	DESTROY_IF(this->peer_id);
+	DESTROY_IF(this->my_id);
+
+	free(this);
+}
+
+/*
+ * Create SM2-KEM instance with pre-distributed keys
+ *
+ * This simulates the R0 certificate exchange phase where both parties
+ * already have their own key pair and the peer's public key.
+ * Since we have peer's EncCert, we can immediately encapsulate.
+ */
+key_exchange_t* gmalg_sm2_ke_create_with_keys(key_exchange_method_t method,
+											  bool is_initiator,
+											  const SM2_KEY *my_key,
+											  const SM2_KEY *peer_pubkey)
+{
+	private_key_exchange_t *this;
+	uint8_t ciphertext[SM2_KEM_CIPHERTEXT_SIZE];
+	size_t ctlen;
+
+	if (method != KE_SM2 || !my_key || !peer_pubkey)
+	{
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.get_method = _get_method,
+			.get_public_key = _get_public_key,
+			.set_public_key = _set_public_key,
+			.get_shared_secret = _get_shared_secret,
+			.destroy = _destroy,
+		},
+		.method = method,
+		.is_initiator = is_initiator,
+		.mock_mode = FALSE,  /* Using real pre-distributed keys */
+		.peer_random_is_initiators = FALSE,
+		.get_pubkey_count = 0,
+	);
+
+	/* Copy our key pair */
+	memcpy(&this->my_key, my_key, sizeof(SM2_KEY));
+
+	/* Copy peer's public key */
+	memcpy(&this->peer_enccert, peer_pubkey, sizeof(SM2_KEY));
+	this->has_peer_enccert = TRUE;
+
+	/* Export our public key for get_public_key */
+	this->my_pubkey = chunk_alloc(SM2_KEM_PUBLIC_KEY_SIZE);
+	if (!export_sm2_public_key(&this->my_key, this->my_pubkey.ptr))
+	{
+		chunk_clear(&this->my_pubkey);
+		free(this);
+		return NULL;
+	}
+
+	/* Since we have peer's EncCert, encapsulate immediately */
+	this->my_random = chunk_alloc(SM2_KEM_RANDOM_SIZE);
+	if (!get_random_bytes(SM2_KEM_RANDOM_SIZE, this->my_random.ptr))
+	{
+		chunk_clear(&this->my_pubkey);
+		chunk_clear(&this->my_random);
+		free(this);
+		return NULL;
+	}
+
+	/* Encrypt our random with peer's EncCert */
+	ctlen = sizeof(ciphertext);
+	if (!sm2_encrypt_data(&this->peer_enccert,
+						  this->my_random.ptr, this->my_random.len,
+						  ciphertext, &ctlen))
+	{
+		chunk_clear(&this->my_pubkey);
+		chunk_clear(&this->my_random);
+		free(this);
+		return NULL;
+	}
+
+	this->my_ciphertext = chunk_alloc(ctlen);
+	memcpy(this->my_ciphertext.ptr, ciphertext, ctlen);
+
+	fprintf(stderr, "DEBUG: Created SM2-KEM with pre-distributed keys, is_initiator=%d, encapsulated\n",
+			is_initiator);
+	fflush(stderr);
+
+	return &this->public;
+}
+
+/*
+ * Create SM2-KEM instance with specified role
+ */
+key_exchange_t* gmalg_sm2_ke_create_with_role(key_exchange_method_t method,
+											  bool is_initiator)
+{
+	private_key_exchange_t *this;
+
+	if (method != KE_SM2)
+	{
+		return NULL;
+	}
+
+	INIT(this,
+		.public = {
+			.get_method = _get_method,
+			.get_public_key = _get_public_key,
+			.set_public_key = _set_public_key,
+			.get_shared_secret = _get_shared_secret,
+			.destroy = _destroy,
+		},
+		.method = method,
+		.is_initiator = is_initiator,
+		.mock_mode = TRUE,  /* Use mock certificates for now */
+		.peer_random_is_initiators = FALSE,
+		.get_pubkey_count = 0,
+	);
+
+	memset(&this->my_key, 0, sizeof(SM2_KEY));
+	memset(&this->peer_enccert, 0, sizeof(SM2_KEY));
+
+	fprintf(stderr, "DEBUG: Created SM2-KEM instance, is_initiator=%d\n", is_initiator);
+	fflush(stderr);
+
+	return &this->public;
+}
+
+/*
+ * Create SM2-KEM instance (defaults to initiator role)
+ */
+key_exchange_t* gmalg_sm2_ke_create(key_exchange_method_t method)
+{
+	return gmalg_sm2_ke_create_with_role(method, TRUE);
+}
