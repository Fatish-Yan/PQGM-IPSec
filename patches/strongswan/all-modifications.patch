+/**
+ * Extract ML-DSA public key from certificate extension
+ *
+ * @param cert_data	DER encoded certificate data
+ * @param pubkey		buffer to store extracted public key (must be MLDSA65_PUBLIC_KEY_BYTES)
+ * @return			TRUE if extraction successful
+ */
+static bool extract_mldsa_pubkey_from_cert(chunk_t cert_data, uint8_t *pubkey)
+{
+	/* Simple DER parsing to find the ML-DSA extension */
+	/* Uses global mldsa_oid defined above */
+
+	size_t i;
+	bool found = FALSE;
+	size_t ext_start = 0;
+
+	/* Search for the OID in the certificate */
+	for (i = 0; i < cert_data.len - sizeof(mldsa_oid); i++)
+	{
+		if (memcmp(cert_data.ptr + i, mldsa_oid, sizeof(mldsa_oid)) == 0)
+		{
+			found = TRUE;
+			ext_start = i + sizeof(mldsa_oid);
+			break;
+		}
+	}
+
+	if (!found)
+	{
+		DBG1(DBG_LIB, "ML-DSA: extension OID not found in certificate");
+		return FALSE;
+	}
+
+	/* Skip the OID and find the OCTET STRING containing the public key */
+	/* Extension format: OID + critical? + OCTET STRING wrapper + actual data */
+	size_t pos = ext_start;
+
+	/* Skip any critical flag (BOOLEAN) */
+	if (pos < cert_data.len && cert_data.ptr[pos] == 0x01)
+	{
+		pos += 3; /* BOOLEAN tag + length + value */
+	}
+
+	/* Expect OCTET STRING (0x04) */
+	if (pos >= cert_data.len || cert_data.ptr[pos] != 0x04)
+	{
+		DBG1(DBG_LIB, "ML-DSA: expected OCTET STRING at position %zu, got 0x%02x",
+			 pos, pos < cert_data.len ? cert_data.ptr[pos] : 0);
+		return FALSE;
+	}
+	pos++;
+
+	/* Parse length */
+	size_t length;
+	if (pos >= cert_data.len)
+	{
+		return FALSE;
+	}
+
+	if ((cert_data.ptr[pos] & 0x80) == 0)
+	{
+		/* Short form length */
+		length = cert_data.ptr[pos];
+		pos++;
+	}
+	else if ((cert_data.ptr[pos] & 0x7F) == 1)
+	{
+		/* Long form, 1 byte length */
+		pos++;
+		if (pos >= cert_data.len)
+		{
+			return FALSE;
+		}
+		length = cert_data.ptr[pos];
+		pos++;
+	}
+	else if ((cert_data.ptr[pos] & 0x7F) == 2)
+	{
+		/* Long form, 2 byte length */
+		pos++;
+		if (pos + 1 >= cert_data.len)
+		{
+			return FALSE;
+		}
+		length = (cert_data.ptr[pos] << 8) | cert_data.ptr[pos + 1];
+		pos += 2;
+	}
+	else
+	{
+		DBG1(DBG_LIB, "ML-DSA: unsupported length encoding");
+		return FALSE;
+	}
+
+	/* Verify length */
+	if (length != MLDSA65_PUBLIC_KEY_BYTES)
+	{
+		DBG1(DBG_LIB, "ML-DSA: extension length %zu != expected %d",
+			 length, MLDSA65_PUBLIC_KEY_BYTES);
+		return FALSE;
+	}
+
+	/* Check bounds */
+	if (pos + length > cert_data.len)
+	{
+		DBG1(DBG_LIB, "ML-DSA: extension data exceeds certificate bounds");
+		return FALSE;
+	}
+
+	/* Extract public key */
+	memcpy(pubkey, cert_data.ptr + pos, MLDSA65_PUBLIC_KEY_BYTES);
+	DBG1(DBG_LIB, "ML-DSA: extracted public key from certificate extension");
+
+	return TRUE;
+}
