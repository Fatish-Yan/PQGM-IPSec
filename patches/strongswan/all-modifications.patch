+/**
+ * Process received SM2 certificates in IKE_INTERMEDIATE
+ * Extract SM2 public key from EncCert and store globally for SM2-KEM
+ */
+static void process_sm2_certs(private_ike_cert_post_t *this, message_t *message)
+{
+	enumerator_t *enumerator;
+	payload_t *payload;
+	cert_payload_t *cert_payload;
+	certificate_t *cert;
+	chunk_t cert_data = chunk_empty;
+	X509_KEY x509_key;
+	SM2_KEY sm2_pubkey;
+
+	typedef void (*set_peer_pubkey_fn)(const void *);
+	typedef int (*x509_get_pubkey_fn)(const uint8_t *, size_t, void *);
+
+	static set_peer_pubkey_fn set_global_peer_pubkey = NULL;
+	static x509_get_pubkey_fn x509_cert_get_pubkey = NULL;
+	static bool symbols_initialized = FALSE;
+
+	/* Resolve symbols once */
+	if (!symbols_initialized)
+	{
+		/* Load GmSSL library */
+		void *gmssl_handle = dlopen("libgmssl.so.3", RTLD_LAZY | RTLD_NOLOAD);
+		if (!gmssl_handle)
+		{
+			gmssl_handle = dlopen("/usr/local/lib/libgmssl.so.3", RTLD_LAZY | RTLD_GLOBAL);
+		}
+
+		if (gmssl_handle)
+		{
+			x509_cert_get_pubkey = (x509_get_pubkey_fn)dlsym(gmssl_handle,
+											"x509_cert_get_subject_public_key");
+		}
+
+		/* Load gmalg plugin */
+		void *gmalg_handle = dlopen("/usr/local/lib/ipsec/plugins/libstrongswan-gmalg.so",
+									RTLD_LAZY | RTLD_NOLOAD);
+		if (!gmalg_handle)
+		{
+			gmalg_handle = dlopen("/usr/local/lib/ipsec/plugins/libstrongswan-gmalg.so",
+								  RTLD_LAZY | RTLD_GLOBAL);
+		}
+		if (gmalg_handle)
+		{
+			set_global_peer_pubkey = (set_peer_pubkey_fn)dlsym(gmalg_handle,
+											"gmalg_set_peer_sm2_pubkey");
+		}
+
+		symbols_initialized = TRUE;
+	}
+
+	enumerator = message->create_payload_enumerator(message);
+	while (enumerator->enumerate(enumerator, &payload))
+	{
+		if (payload->get_type(payload) == PLV2_CERTIFICATE)
+		{
+			cert_payload = (cert_payload_t*)payload;
+
+			/* Get certificate from payload */
+			cert = cert_payload->get_cert(cert_payload);
+			if (!cert)
+			{
+				DBG1(DBG_IKE, "PQ-GM-IKEv2: could not get certificate from payload");
+				continue;
+			}
+
+			/* Get DER encoding */
+			if (!cert->get_encoding(cert, CERT_ASN1_DER, &cert_data))
+			{
+				DBG1(DBG_IKE, "PQ-GM-IKEv2: could not get DER encoding of certificate");
+				cert->destroy(cert);
+				continue;
+			}
+
+			if (cert_data.len > 0)
+			{
+				DBG1(DBG_IKE, "PQ-GM-IKEv2: received certificate (%zu bytes), "
+					 "trying to extract SM2 public key", cert_data.len);
+
+				memset(&x509_key, 0, sizeof(X509_KEY));
+
+				/* Extract public key from certificate using GmSSL */
+				if (x509_cert_get_pubkey &&
+					x509_cert_get_pubkey(cert_data.ptr, cert_data.len,
+										 &x509_key) == 1)
+				{
+					/* Check if it's an SM2 key (OID_sm2 = 1.2.156.10197.1.301) */
+					if (x509_key.algor == 17 ||  /* OID_sm2 */
+						x509_key.algor == 19)    /* OID_ec_public_key */
+					{
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: found SM2 public key in certificate (algor=%d)",
+							 x509_key.algor);
+
+						/* Copy SM2 key */
+						memcpy(&sm2_pubkey, &x509_key.u.sm2_key, sizeof(SM2_KEY));
+
+						/* Store globally for SM2-KEM */
+						if (set_global_peer_pubkey)
+						{
+							set_global_peer_pubkey(&sm2_pubkey);
+							DBG1(DBG_IKE, "PQ-GM-IKEv2: stored peer SM2 pubkey globally");
+						}
+					}
+					else
+					{
+						DBG1(DBG_IKE, "PQ-GM-IKEv2: certificate key is not SM2 (algor=%d)", x509_key.algor);
+					}
+				}
+				else
+				{
+					DBG1(DBG_IKE, "PQ-GM-IKEv2: could not extract public key from certificate");
+				}
+				chunk_free(&cert_data);
+			}
+			cert->destroy(cert);
+		}
+	}
+	enumerator->destroy(enumerator);
+}
+
 METHOD(task_t, process_r, status_t,
 	private_ike_cert_post_t *this, message_t *message)
 {
+	switch (message->get_exchange_type(message))
+	{
+		case IKE_INTERMEDIATE:
+			/* PQ-GM-IKEv2: Process received SM2 certificates */
+			if (message->get_message_id(message) == 1)  /* First IKE_INTERMEDIATE */
+			{
+				DBG1(DBG_IKE, "PQ-GM-IKEv2: processing certificates in IKE_INTERMEDIATE #0");
+				process_sm2_certs(this, message);
+			}
+			break;
+		default:
+			break;
+	}
 	return NEED_MORE;
 }
 
